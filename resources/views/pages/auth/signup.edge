    padding: 40px;
    width: 100%;
    max-width: 420px;
  }
  .auth-title { font-size: 26px; font-weight: 600; color: #202124; margin-bottom: 24px; }
  .auth-field { margin-bottom: 18px; }
  .auth-field label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: #6b7a99;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin-bottom: 6px;
  }
  .auth-field input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid rgba(0,0,0,0.15);
    border-radius: 10px;
    font-size: 14px;
    font-family: 'Google Sans', sans-serif;
    outline: none;
    transition: border-color 0.2s;
  }
  .auth-field input:focus { border-color: #202124; }
  .auth-error-banner {
    background: #fff0f0;
    border: 1px solid #ffc0c0;
