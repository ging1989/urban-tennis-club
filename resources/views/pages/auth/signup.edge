<style>
  .auth-wrap {
    min-height: calc(100vh - 68px);
    margin-top: 68px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f5f5;
  }
  .auth-card {
    background: white;
    border: 1px solid rgba(0,0,0,0.08);
