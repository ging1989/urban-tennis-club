<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Urban Tennis Club</title>
  <meta name="csrf-token" content="{{ csrfToken }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

  {{-- ── SIDEBAR ── --}}
  <aside class="sidebar">
    <div class="sidebar-logo">
      <span class="logo-icon">🎾</span>
      <span class="logo-text">Urban Tennis</span>
    </div>

    <div class="nav-label">NAVIGATION</div>

    <nav class="sidebar-nav">
      <a href="#" class="nav-item active" data-section="dashboard">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        </span>
        Dashboard
      </a>
      <a href="#" class="nav-item" data-section="report">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </span>
        Reports
      </a>
      <a href="#" class="nav-item" data-section="courts">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
        </span>
        Court Management
      </a>
      <a href="#" class="nav-item" data-section="coaches">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </span>
        Coach Management
      </a>
      <a href="#" class="nav-item" data-section="members">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
        Customer Management
      </a>
      <a href="#" class="nav-item" data-section="tiers">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
        Tier Management
      </a>
      <a href="#" class="nav-item" data-section="users">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </span>
        User Management
      </a>
    </nav>

    <div class="sidebar-footer">
      <a href="/" class="footer-link">← Back to Site</a>
    </div>
  </aside>

  {{-- ── MAIN ── --}}
  <div class="admin-main">

    {{-- Topbar --}}
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <span class="breadcrumb-home">Home</span>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current" id="breadcrumb-current">Dashboard</span>
      </div>
      <div class="topbar-right">
        <span class="topbar-user">{{ auth.user ? (auth.user.fullName ?? auth.user.email) : '' }}</span>
        <form action="{{ route('admin.logout') }}" method="post" style="display:inline">
          {{ csrfField() }}
          <button type="submit" class="btn-logout">Logout</button>
        </form>
      </div>
    </header>

    <div class="admin-content">

      {{-- ══ DASHBOARD ══ --}}
      <section id="section-dashboard" class="admin-section active">
        <div class="section-header">
          <h1 class="section-title">Dashboard</h1>
        </div>

        {{-- Stat Cards --}}
        <div class="stat-grid">

          {{-- Hero card: Today's Revenue --}}
          <div class="stat-card stat-card--hero">
            <div class="stat-hero-label">Today's Revenue</div>
            <div class="stat-hero-value" id="kpi-revenue"><span class="hero-currency">฿</span>{{ stats.todayRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</div>
            <div class="stat-hero-trend">Non-cancelled bookings</div>
          </div>

          {{-- Other cards --}}
          <div class="stat-card stat-card--center">
            <div class="stat-label">Bookings</div>
            <div class="stat-value" id="kpi-bookings">{{ stats.todayBookings }}</div>
            <div class="stat-trend">Today</div>
          </div>
          <div class="stat-card stat-card--center">
            <div class="stat-label">Customers</div>
            <div class="stat-value amber" id="kpi-customers">{{ stats.todayCustomers }}</div>
            <div class="stat-trend">Today</div>
          </div>
          <div class="stat-card stat-card--center">
            <div class="stat-label">Available Courts</div>
            <div class="stat-value" style="color:var(--red)" id="kpi-courts">{{ stats.availableCourts }}</div>
            <div class="stat-trend">Today</div>
          </div>
          <div class="stat-card stat-card--center">
            <div class="stat-label">Coach Revenue</div>
            <div class="stat-value" style="color:var(--blue)" id="kpi-coach-revenue">฿{{ stats.todayCoachRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</div>
            <div class="stat-trend">Today</div>
          </div>
        </div>

        {{-- Charts Row --}}
        <div class="two-col">
          <div class="panel">
            <div class="panel-title">Bookings — Last 7 Days</div>
            <div class="bar-chart">
              @each(day in last7)
                <div class="bar-col">
                  <div class="bar-count">{{ day.count }}</div>
                  <div
                    class="bar {{ day.count === 0 ? 'zero' : '' }}"
                    style="height: {{ day.count === 0 ? '4px' : 'calc(' + day.count + ' / ' + Math.max(...last7.map(d => d.count), 1) + ' * 80px)' }}"
                  ></div>
                  <div class="bar-label">{{ day.date.slice(5) }}</div>
                </div>
              @end
            </div>
          </div>

          <div class="panel">
            <div class="panel-title">Booking Status Today</div>
            <div class="status-row">
              <span class="status-dot dot-confirmed"></span>
              <span class="status-name">Confirmed</span>
              <div class="status-bar-wrap">
                <div class="status-bar-fill" id="status-confirmed-bar" style="width:{{ (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) > 0 ? (stats.confirmedCount / (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) * 100).toFixed(1) : 0 }}%;background:var(--green);"></div>
              </div>
              <span class="status-count" id="status-confirmed-count">{{ stats.confirmedCount }}</span>
            </div>
            <div class="status-row">
              <span class="status-dot dot-pending"></span>
              <span class="status-name">Pending</span>
              <div class="status-bar-wrap">
                <div class="status-bar-fill" id="status-pending-bar" style="width:{{ (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) > 0 ? (stats.pendingCount / (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) * 100).toFixed(1) : 0 }}%;background:var(--amber);"></div>
              </div>
              <span class="status-count" id="status-pending-count">{{ stats.pendingCount }}</span>
            </div>
            <div class="status-row">
              <span class="status-dot dot-cancelled"></span>
              <span class="status-name">Cancelled</span>
              <div class="status-bar-wrap">
                <div class="status-bar-fill" id="status-cancelled-bar" style="width:{{ (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) > 0 ? (stats.cancelledCount / (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) * 100).toFixed(1) : 0 }}%;background:var(--red);"></div>
              </div>
              <span class="status-count" id="status-cancelled-count">{{ stats.cancelledCount }}</span>
            </div>
          </div>
        </div>

        {{-- Coach Charts --}}
        <div class="two-col" style="margin-bottom:24px">

          {{-- Line chart: coach revenue last 7 days --}}
          <div class="panel">
            <div class="panel-title">Coach Revenue — Last 7 Days</div>
            <div class="line-chart-wrap">
              <svg class="line-chart-svg" viewBox="0 0 420 90" preserveAspectRatio="none"
                data-points="{{ last7CoachRevenue.map(d => d.revenue).join(',') }}">
                <defs>
                  <linearGradient id="coachGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#2ea043" stop-opacity="0.25"/>
                    <stop offset="100%" stop-color="#2ea043" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path class="line-area" fill="url(#coachGrad)"/>
                <path class="line-path" fill="none" stroke="#2ea043" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
              </svg>
              <div class="line-labels">
                @each(day in last7CoachRevenue)
                  <span>{{ day.date.slice(5) }}</span>
                @end
              </div>
            </div>
          </div>

          {{-- Bar chart: coach revenue today per coach --}}
          <div class="panel">
            <div class="panel-title">Coach Revenue Today</div>
            @if(coachRevenueToday.length === 0)
              <div style="color:var(--muted);font-size:13px;padding:16px 0;text-align:center">No coach bookings today</div>
            @else
              <div class="bar-chart" style="height:110px">
                @each(c in coachRevenueToday)
                  <div class="bar-col">
                    <div class="bar-count" style="font-size:9px">฿{{ c.revenue.toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</div>
                    <div
                      class="bar bar--coach"
                      style="height: calc({{ c.revenue }} / {{ Math.max(...coachRevenueToday.map(x => x.revenue), 1) }} * 80px)"
                    ></div>
                    <div class="bar-label">{{ c.name }}</div>
                  </div>
                @end
              </div>
            @end
          </div>

        </div>


      </section>

      {{-- ══ REPORTS ══ --}}
      <section id="section-report" class="admin-section">
        <div class="section-header">
          <h1 class="section-title">Reports</h1>
        </div>
        <div class="panel">
          <div class="panel-title">Recent Bookings (50 latest)</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Customer</th>
                  <th>Court</th>
                  <th>Date</th>
                  <th>Time</th>
                  <th>Total</th>
                  <th>Payment</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                @each(b in recentBookings)
                  <tr>
                    <td class="td-muted">#{{ b.bookingId }}</td>
                    <td>{{ b.customer ? b.customer.customerName : '—' }}</td>
                    <td>{{ b.court ? b.court.courtName : '—' }}</td>
                    <td class="td-muted">{{ b.bookingDate }}</td>
                    <td class="td-muted">{{ b.bookingStart }} – {{ b.bookingEnd }}</td>
                    <td>฿{{ parseFloat(b.totalPrice).toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</td>
                    <td class="td-muted">{{ b.payment ? b.payment.paymentMethod : '—' }}</td>
                    <td><span class="badge badge-{{ b.bookingStatus }}">{{ b.bookingStatus }}</span></td>
                    <td>
                      @if(b.bookingStatus === 'pending')
                        <div class="action-btns">
                          <button class="btn-action confirm" data-action="confirmed" data-id="{{ b.bookingId }}">Confirm</button>
                          <button class="btn-action cancel"  data-action="cancelled" data-id="{{ b.bookingId }}">Cancel</button>
                        </div>
                      @else
                        <span class="td-muted">—</span>
                      @end
                    </td>
                  </tr>
                @end
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {{-- ══ COURT MANAGEMENT ══ --}}
      <section id="section-courts" class="admin-section">
        <div class="section-header" style="display:flex;align-items:center;justify-content:space-between">
          <h1 class="section-title">Court Management</h1>
          <button class="btn-primary" id="btn-add-court">+ Add Court</button>
        </div>
        <div class="panel">
          <div class="panel-title">All Courts</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Court Name</th>
                  <th>Price/hr</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="courts-tbody">
                @each(court in courts)
                  <tr id="court-row-{{ court.courtId }}">
                    <td class="td-muted">{{ court.courtId }}</td>
                    <td>{{ court.courtName }}</td>
                    <td>฿{{ court.courtPricePerHr }}</td>
                    <td>
                      <span class="badge {{ ['available','indoor','outdoor'].includes(court.courtStatus) ? 'badge-confirmed' : 'badge-cancelled' }}">
                        {{ court.courtStatus ?? '—' }}
                      </span>
                    </td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-action btn-edit btn-edit-court"
                          data-id="{{ court.courtId }}"
                          data-name="{{ court.courtName }}"
                          data-price="{{ court.courtPricePerHr }}"
                          data-status="{{ court.courtStatus }}">
                          Edit
                        </button>
                        <button class="btn-action cancel btn-delete-court" data-id="{{ court.courtId }}" data-name="{{ court.courtName }}">
                          Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                @end
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {{-- ══ COACH SCHEDULE MODAL ══ --}}
      <div id="schedule-modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal" style="max-width:520px">
          <div class="modal-header">
            <h2 class="modal-title">Weekly Schedule — <span id="schedule-coach-name"></span></h2>
            <button class="modal-close" id="schedule-modal-close">&times;</button>
          </div>
          <p style="font-size:12.5px;color:var(--muted);margin-bottom:16px">เปิด/ปิดวันที่ coach ว่าง และกำหนดเวลา</p>
          <div id="schedule-days"></div>
        </div>
      </div>

      {{-- ══ COURT MODAL ══ --}}
      <div id="court-modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal">
          <div class="modal-header">
            <h2 class="modal-title" id="court-modal-title">Add Court</h2>
            <button class="modal-close" id="court-modal-close">&times;</button>
          </div>
          <form id="court-form">
            <input type="hidden" id="court-id" value="">
            <div class="form-group">
              <label class="form-label">Court Name</label>
              <input type="text" id="court-name" class="form-input" placeholder="e.g. Court A" required>
            </div>
            <div class="form-group">
              <label class="form-label">Price / hr (฿)</label>
              <input type="number" id="court-price" class="form-input" placeholder="e.g. 300" min="0" required>
            </div>
            <div class="form-group">
              <label class="form-label">Status</label>
              <select id="court-status" class="form-input">
                <option value="available">available</option>
                <option value="unavailable">unavailable</option>
              </select>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn-secondary" id="court-modal-cancel">Cancel</button>
              <button type="submit" class="btn-primary" id="court-submit-btn">Save</button>
            </div>
          </form>
        </div>
      </div>

      {{-- ══ CONFIRM DELETE MODAL ══ --}}
      <div id="delete-modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal" style="max-width:380px">
          <div class="modal-header">
            <h2 class="modal-title">Delete Court</h2>
            <button class="modal-close" id="delete-modal-close">&times;</button>
          </div>
          <p style="font-size:14px;color:var(--ink);margin-bottom:8px;">
            Are you sure you want to delete <strong id="delete-court-name"></strong>?
          </p>
          <p style="font-size:12.5px;color:var(--muted);margin-bottom:4px;">This action cannot be undone. Courts with existing bookings cannot be deleted.</p>
          <div class="modal-footer">
            <button type="button" class="btn-secondary" id="delete-modal-cancel">Cancel</button>
            <button type="button" class="btn-primary" id="delete-confirm-btn" style="background:var(--red)">Delete</button>
          </div>
        </div>
      </div>

      {{-- ══ COACH MANAGEMENT ══ --}}
      <section id="section-coaches" class="admin-section">
        <div class="section-header" style="display:flex;align-items:center;justify-content:space-between">
          <h1 class="section-title">Coach Management</h1>
          <button class="btn-primary" id="btn-add-coach">+ Add Coach</button>
        </div>
        <div class="panel">
          <div class="panel-title">All Coaches</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Level</th>
                  <th>Price/hr</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                @each(coach in coaches)
                  <tr>
                    <td class="td-muted">{{ coach.coachId }}</td>
                    <td>{{ coach.coachName }}</td>
                    <td class="td-muted">{{ coach.coachPricing ? coach.coachPricing.coachLevelDesc : '—' }}</td>
                    <td>฿{{ coach.coachPricing ? coach.coachPricing.coachPrice : '—' }}</td>
                    <td>
                      <span class="badge {{ coach.coachStatus === 'available' ? 'badge-confirmed' : 'badge-pending' }}">
                        {{ coach.coachStatus }}
                      </span>
                    </td>
                    <td>
                      <button class="btn-action btn-edit btn-edit-coach"
                        data-id="{{ coach.coachId }}"
                        data-name="{{ coach.coachName }}"
                        data-level="{{ coach.coachLevelId }}"
                        data-status="{{ coach.coachStatus }}">
                        Edit
                      </button>
                      <button class="btn-action confirm btn-schedule-coach"
                        data-id="{{ coach.coachId }}"
                        data-name="{{ coach.coachName }}"
                        data-schedules="{{ JSON.stringify(coach.coachSchedules.map(s => ({ day: s.dayOfWeek, start: s.startTime, end: s.endTime }))) }}">
                        Schedule
                      </button>
                    </td>
                  </tr>
                @end
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {{-- ══ COACH MODAL ══ --}}
      <div id="coach-modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal">
          <div class="modal-header">
            <h2 class="modal-title" id="coach-modal-title">Add Coach</h2>
            <button class="modal-close" id="coach-modal-close">&times;</button>
          </div>
          <form id="coach-form">
            <input type="hidden" id="coach-id" value="">
            <div class="form-group">
              <label class="form-label">Name</label>
              <input type="text" id="coach-name" class="form-input" placeholder="Coach name" required>
            </div>
            <div class="form-group">
              <label class="form-label">Level</label>
              <select id="coach-level" class="form-input">
                @each(p in coachPricings)
                  <option value="{{ p.coachLevelId }}">{{ p.coachLevelDesc }} (฿{{ p.coachPrice }}/hr)</option>
                @end
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Status</label>
              <select id="coach-status" class="form-input">
                <option value="available">Available</option>
                <option value="unavailable">Unavailable</option>
              </select>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn-secondary" id="coach-modal-cancel">Cancel</button>
              <button type="submit" class="btn-primary" id="coach-submit-btn">Save</button>
            </div>
          </form>
        </div>
      </div>

      {{-- ══ MEMBER MANAGEMENT ══ --}}
      <section id="section-members" class="admin-section">
        <div class="section-header">
          <h1 class="section-title">Customer Management</h1>
        </div>
        <div class="panel">
          <div class="panel-title">All Customer</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Type</th>
                  <th>Tier</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                @each(c in customers)
                  <tr id="customer-row-{{ c.customerId }}">
                    <td class="td-muted">{{ c.customerId }}</td>
                    <td>{{ c.customerName }}</td>
                    <td class="td-muted">{{ c.customerEmail ?? '—' }}</td>
                    <td class="td-muted">{{ c.customerPhone ?? '—' }}</td>
                    <td><span class="badge badge-confirmed">{{ c.customerType }}</span></td>
                    <td class="td-muted">{{ c.tier ? c.tier.tierDesc : '—' }}</td>
                    <td>
                      <button class="btn-action btn-edit btn-edit-customer"
                        data-id="{{ c.customerId }}"
                        data-name="{{ c.customerName }}"
                        data-email="{{ c.customerEmail ?? '' }}"
                        data-phone="{{ c.customerPhone ?? '' }}"
                        data-type="{{ c.customerType }}"
                        data-tier="{{ c.tierId ?? '' }}"
                        data-user="{{ c.userId ?? '' }}">
                        Edit
                      </button>
                    </td>
                  </tr>
                @end
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {{-- ══ CUSTOMER EDIT MODAL ══ --}}
      <div id="customer-modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal">
          <div class="modal-header">
            <h2 class="modal-title">Edit Customer</h2>
            <button class="modal-close" id="customer-modal-close">&times;</button>
          </div>
          <form id="customer-form">
            <input type="hidden" id="customer-id" value="">
            <div class="form-group">
              <label class="form-label">Name</label>
              <input type="text" id="customer-name" class="form-input" required>
            </div>
            <div class="form-group">
              <label class="form-label">Email</label>
              <input type="email" id="customer-email" class="form-input" placeholder="—">
            </div>
            <div class="form-group">
              <label class="form-label">Phone</label>
              <input type="text" id="customer-phone" class="form-input" placeholder="—">
            </div>
            <div class="form-group">
              <label class="form-label">Type</label>
              <select id="customer-type" class="form-input">
                <option value="guest">guest</option>
                <option value="member">member</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Tier</label>
              <select id="customer-tier" class="form-input">
                <option value="">— No tier —</option>
                @each(t in tiers)
                  <option value="{{ t.tierId }}">{{ t.tierDesc }} ({{ t.tierDiscount }}% off, min {{ t.minHours }} hrs)</option>
                @end
              </select>
            </div>
            <div class="form-group" id="customer-user-group" style="display:none">
              <label class="form-label">Link User Account</label>
              <select id="customer-user" class="form-input">
                <option value="">— Not linked —</option>
                @each(u in memberUsers)
                  <option value="{{ u.id }}">{{ u.fullName ?? u.email }} ({{ u.email }})</option>
                @end
              </select>
              <p style="font-size:11.5px;color:var(--muted);margin-top:5px;">เชื่อม customer นี้กับ user account ที่ login ได้</p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn-secondary" id="customer-modal-cancel">Cancel</button>
              <button type="submit" class="btn-primary" id="customer-submit-btn">Save Changes</button>
            </div>
          </form>
        </div>
      </div>

      {{-- ══ TIER MANAGEMENT ══ --}}
      <section id="section-tiers" class="admin-section">
        <div class="section-header" style="display:flex;align-items:center;justify-content:space-between">
          <h1 class="section-title">Tier Management</h1>
          <button class="btn-primary" id="btn-add-tier">+ Add Tier</button>
        </div>
        <div class="panel">
          <div class="panel-title">All Tiers</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Tier Name</th>
                  <th>Min Hours</th>
                  <th>Discount (%)</th>
                  <th>Members</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="tiers-tbody">
                @each(tier in tiers)
                  <tr id="tier-row-{{ tier.tierId }}">
                    <td class="td-muted">{{ tier.tierId }}</td>
                    <td>{{ tier.tierDesc }}</td>
                    <td class="td-muted">{{ tier.minHours }} hrs</td>
                    <td><span class="badge badge-confirmed">{{ tier.tierDiscount }}%</span></td>
                    <td class="td-muted">{{ tier.members ? tier.members.length : 0 }}</td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-action btn-edit btn-edit-tier"
                          data-id="{{ tier.tierId }}"
                          data-desc="{{ tier.tierDesc }}"
                          data-hours="{{ tier.minHours }}"
                          data-discount="{{ tier.tierDiscount }}">
                          Edit
                        </button>
                        <button class="btn-action cancel btn-delete-tier"
                          data-id="{{ tier.tierId }}"
                          data-desc="{{ tier.tierDesc }}">
                          Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                @end
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {{-- ══ TIER MODAL ══ --}}
      <div id="tier-modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal">
          <div class="modal-header">
            <h2 class="modal-title" id="tier-modal-title">Add Tier</h2>
            <button class="modal-close" id="tier-modal-close">&times;</button>
          </div>
          <form id="tier-form">
            <input type="hidden" id="tier-id" value="">
            <div class="form-group">
              <label class="form-label">Tier Name</label>
              <input type="text" id="tier-desc" class="form-input" placeholder="e.g. Silver" required>
            </div>
            <div class="form-group">
              <label class="form-label">Minimum Hours</label>
              <input type="number" id="tier-hours" class="form-input" placeholder="e.g. 10" min="0" required>
            </div>
            <div class="form-group">
              <label class="form-label">Discount (%)</label>
              <input type="number" id="tier-discount" class="form-input" placeholder="e.g. 10" min="0" max="100" required>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn-secondary" id="tier-modal-cancel">Cancel</button>
              <button type="submit" class="btn-primary" id="tier-submit-btn">Save</button>
            </div>
          </form>
        </div>
      </div>

      {{-- ══ TIER DELETE MODAL ══ --}}
      <div id="tier-delete-overlay" class="modal-overlay" style="display:none">
        <div class="modal" style="max-width:380px">
          <div class="modal-header">
            <h2 class="modal-title">Delete Tier</h2>
            <button class="modal-close" id="tier-delete-close">&times;</button>
          </div>
          <p style="font-size:14px;color:var(--ink);margin-bottom:8px;">
            Are you sure you want to delete <strong id="delete-tier-desc"></strong>?
          </p>
          <p style="font-size:12.5px;color:var(--muted);margin-bottom:4px;">Tiers that have members assigned cannot be deleted.</p>
          <div class="modal-footer">
            <button type="button" class="btn-secondary" id="tier-delete-cancel">Cancel</button>
            <button type="button" class="btn-primary" id="tier-delete-confirm" style="background:var(--red)">Delete</button>
          </div>
        </div>
      </div>

      {{-- ══ USER MANAGEMENT ══ --}}
      <section id="section-users" class="admin-section">
        <div class="section-header" style="display:flex;align-items:center;justify-content:space-between">
          <h1 class="section-title">User Management</h1>
          <button class="btn-primary" id="btn-add-user">+ Add User</button>
        </div>
        <div class="panel">
          <div class="panel-title">All Users</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Full Name</th>
                  <th>Username</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Tier</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="users-tbody">
                @each(u in users)
                  <tr id="user-row-{{ u.id }}">
                    <td class="td-muted">{{ u.id }}</td>
                    <td>{{ u.fullName ?? '—' }}</td>
                    <td class="td-muted">{{ u.username ?? '—' }}</td>
                    <td class="td-muted">{{ u.email }}</td>
                    <td>
                      <span class="badge {{ u.role === 'admin' ? 'badge-cancelled' : 'badge-confirmed' }}">
                        {{ u.role }}
                      </span>
                    </td>
                    <td class="td-muted">
                      @if(u.role === 'member' && u.customer && u.customer.tier)
                        {{ u.customer.tier.tierDesc }}
                      @elseif(u.role === 'member')
                        <span style="color:var(--muted)">—</span>
                      @else
                        <span style="color:var(--muted)">—</span>
                      @end
                    </td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-action btn-edit btn-edit-user"
                          data-id="{{ u.id }}"
                          data-fullname="{{ u.fullName ?? '' }}"
                          data-username="{{ u.username ?? '' }}"
                          data-email="{{ u.email }}"
                          data-role="{{ u.role }}">
                          Edit
                        </button>
                        <button class="btn-action cancel btn-delete-user"
                          data-id="{{ u.id }}"
                          data-name="{{ u.fullName ?? u.email }}">
                          Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                @end
              </tbody>
            </table>
          </div>
        </div>
      </section>

      {{-- ══ USER MODAL (Add / Edit) ══ --}}
      <div id="user-modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal">
          <div class="modal-header">
            <h2 class="modal-title" id="user-modal-title">Add User</h2>
            <button class="modal-close" id="user-modal-close">&times;</button>
          </div>
          <form id="user-form">
            <input type="hidden" id="user-id" value="">
            <div class="form-group">
              <label class="form-label">Full Name</label>
              <input type="text" id="user-fullname" class="form-input" placeholder="Somchai Jaidee">
            </div>
            <div class="form-group">
              <label class="form-label">Username</label>
              <input type="text" id="user-username" class="form-input" placeholder="somchai">
            </div>
            <div class="form-group">
              <label class="form-label">Email</label>
              <input type="email" id="user-email" class="form-input" required>
            </div>
            <div class="form-group" id="user-password-group">
              <label class="form-label">Password</label>
              <input type="password" id="user-password" class="form-input" placeholder="••••••••">
              <p id="user-password-hint" style="font-size:11.5px;color:var(--muted);margin-top:5px;display:none">เว้นว่างไว้ถ้าไม่ต้องการเปลี่ยน password</p>
            </div>
            <div class="form-group">
              <label class="form-label">Role</label>
              <select id="user-role" class="form-input">
                <option value="member">member</option>
                <option value="admin">admin</option>
              </select>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn-secondary" id="user-modal-cancel">Cancel</button>
              <button type="submit" class="btn-primary" id="user-submit-btn">Add User</button>
            </div>
          </form>
        </div>
      </div>

      {{-- ══ USER DELETE MODAL ══ --}}
      <div id="user-delete-overlay" class="modal-overlay" style="display:none">
        <div class="modal" style="max-width:380px">
          <div class="modal-header">
            <h2 class="modal-title">Delete User</h2>
            <button class="modal-close" id="user-delete-close">&times;</button>
          </div>
          <p style="font-size:14px;color:var(--ink);margin-bottom:8px;">
            Are you sure you want to delete <strong id="delete-user-name"></strong>?
          </p>
          <p style="font-size:12.5px;color:var(--muted);margin-bottom:4px;">This action cannot be undone.</p>
          <div class="modal-footer">
            <button type="button" class="btn-secondary" id="user-delete-cancel">Cancel</button>
            <button type="button" class="btn-primary" id="user-delete-confirm" style="background:var(--red)">Delete</button>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    // ── Tab switching ──
    const navItems = document.querySelectorAll('.nav-item')
    const sections = document.querySelectorAll('.admin-section')
    const breadcrumb = document.getElementById('breadcrumb-current')

    function activateSection(target) {
      const item = document.querySelector(`.nav-item[data-section="${target}"]`)
      if (!item) return
      navItems.forEach(i => i.classList.remove('active'))
      sections.forEach(s => s.classList.remove('active'))
      item.classList.add('active')
      document.getElementById('section-' + target).classList.add('active')
      breadcrumb.textContent = item.textContent.trim()
    }

    navItems.forEach(item => {
      item.addEventListener('click', e => {
        e.preventDefault()
        const target = item.dataset.section
        activateSection(target)
        history.replaceState(null, '', '#' + target)
      })
    })

    // restore section from URL hash on load
    const hash = window.location.hash.replace('#', '')
    if (hash) activateSection(hash)

    // ── Line chart ──
    function drawLineChart(svg) {
      const raw = svg.dataset.points || ''
      const values = raw.split(',').map(Number)
      const n = values.length
      if (n < 2) return
      const W = 420, H = 90, pad = 8
      const max = Math.max(...values, 1)
      const pts = values.map((v, i) => [
        pad + (i / (n - 1)) * (W - pad * 2),
        H - pad - (v / max) * (H - pad * 2)
      ])
      const linePts = pts.map(([x, y]) => `${x},${y}`).join(' L ')
      const areaD = `M ${pts[0][0]},${H} L ${pts.map(([x,y]) => `${x},${y}`).join(' L ')} L ${pts[n-1][0]},${H} Z`
      svg.querySelector('.line-path').setAttribute('d', `M ${linePts}`)
      svg.querySelector('.line-area').setAttribute('d', areaD)
    }
    document.querySelectorAll('.line-chart-svg').forEach(drawLineChart)

    // ── KPI refresh ──
    async function refreshStats() {
      try {
        const res = await fetch('/admin/stats')
        if (!res.ok) return
        const s = await res.json()
        const totalStatus = s.pendingCount + s.confirmedCount + s.cancelledCount
        document.getElementById('kpi-bookings').textContent      = s.todayBookings
        document.getElementById('kpi-revenue').innerHTML          = '<span class="hero-currency">฿</span>' + s.todayRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 })
        document.getElementById('kpi-customers').textContent     = s.todayCustomers
        document.getElementById('kpi-courts').textContent        = s.availableCourts
        document.getElementById('kpi-coach-revenue').textContent = '฿' + s.todayCoachRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 })
        document.getElementById('status-confirmed-count').textContent = s.confirmedCount
        document.getElementById('status-pending-count').textContent = s.pendingCount
        document.getElementById('status-cancelled-count').textContent = s.cancelledCount
        document.getElementById('status-confirmed-bar').style.width = `${totalStatus > 0 ? ((s.confirmedCount / totalStatus) * 100).toFixed(1) : 0}%`
        document.getElementById('status-pending-bar').style.width = `${totalStatus > 0 ? ((s.pendingCount / totalStatus) * 100).toFixed(1) : 0}%`
        document.getElementById('status-cancelled-bar').style.width = `${totalStatus > 0 ? ((s.cancelledCount / totalStatus) * 100).toFixed(1) : 0}%`
      } catch {}
    }

    // Auto-poll ทุก 30 วินาที
    setInterval(refreshStats, 30000)

    // ── Coach Modal ──
    const coachOverlay  = document.getElementById('coach-modal-overlay')
    const coachTitle    = document.getElementById('coach-modal-title')
    const coachForm     = document.getElementById('coach-form')
    const coachIdInput  = document.getElementById('coach-id')
    const coachName     = document.getElementById('coach-name')
    const coachLevel    = document.getElementById('coach-level')
    const coachStatus   = document.getElementById('coach-status')
    const coachSubmit   = document.getElementById('coach-submit-btn')

    function openCoachModal({ id = '', name = '', level = '', status = 'available' } = {}) {
      coachIdInput.value  = id
      coachName.value     = name
      coachLevel.value    = level
      coachStatus.value   = status
      coachTitle.textContent = id ? 'Edit Coach' : 'Add Coach'
      coachSubmit.textContent = id ? 'Save Changes' : 'Add Coach'
      coachOverlay.style.display = 'flex'
    }
    function closeCoachModal() {
      coachOverlay.style.display = 'none'
      coachForm.reset()
    }

    document.getElementById('btn-add-coach').addEventListener('click', () => openCoachModal())
    document.getElementById('coach-modal-close').addEventListener('click', closeCoachModal)
    document.getElementById('coach-modal-cancel').addEventListener('click', closeCoachModal)
    coachOverlay.addEventListener('click', e => { if (e.target === coachOverlay) closeCoachModal() })

    document.querySelectorAll('.btn-edit-coach').forEach(btn => {
      btn.addEventListener('click', () => openCoachModal({
        id:     btn.dataset.id,
        name:   btn.dataset.name,
        level:  btn.dataset.level,
        status: btn.dataset.status,
      }))
    })

    // ── Coach Schedule Modal ──
    const DAY_NAMES = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']
    const scheduleOverlay = document.getElementById('schedule-modal-overlay')
    const scheduleCoachName = document.getElementById('schedule-coach-name')
    const scheduleDays = document.getElementById('schedule-days')
    let scheduleCoachId = null

    function openScheduleModal(coachId, coachName, schedules) {
      scheduleCoachId = coachId
      scheduleCoachName.textContent = coachName
      renderScheduleDays(schedules)
      scheduleOverlay.style.display = 'flex'
    }
    function closeScheduleModal() {
      scheduleOverlay.style.display = 'none'
    }

    function renderScheduleDays(schedules) {
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      scheduleDays.innerHTML = DAY_NAMES.map((name, day) => {
        const s = schedules.find(x => x.day === day)
        return `<div class="sched-row" id="sched-row-${day}" style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)">
          <label style="display:flex;align-items:center;gap:8px;min-width:60px;cursor:pointer">
            <input type="checkbox" id="sched-cb-${day}" ${s ? 'checked' : ''} onchange="toggleScheduleDay(${day}, this.checked)" style="width:16px;height:16px;cursor:pointer">
            <span style="font-weight:600;font-size:13px">${name}</span>
          </label>
          <div id="sched-times-${day}" style="display:flex;gap:8px;align-items:center;flex:1;${s ? '' : 'opacity:0.35;pointer-events:none'}">
            <input type="time" id="sched-start-${day}" value="${s ? s.start : '09:00'}" class="form-input" style="width:120px;padding:6px 10px" onchange="saveScheduleDay(${day})">
            <span style="color:var(--muted);font-size:13px">–</span>
            <input type="time" id="sched-end-${day}" value="${s ? s.end : '18:00'}" class="form-input" style="width:120px;padding:6px 10px" onchange="saveScheduleDay(${day})">
          </div>
          <span id="sched-status-${day}" style="font-size:11px;color:var(--muted);min-width:50px;text-align:right"></span>
        </div>`
      }).join('')
    }

    async function toggleScheduleDay(day, enabled) {
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      const times = document.getElementById(`sched-times-${day}`)
      if (!enabled) {
        times.style.opacity = '0.35'
        times.style.pointerEvents = 'none'
        await fetch(`/admin/coaches/${scheduleCoachId}/schedule/${day}`, {
          method: 'DELETE', headers: { 'X-CSRF-TOKEN': csrf }
        })
        setSchedStatus(day, '')
      } else {
        times.style.opacity = '1'
        times.style.pointerEvents = ''
        await saveScheduleDay(day)
      }
    }

    async function saveScheduleDay(day) {
      const cb = document.getElementById(`sched-cb-${day}`)
      if (!cb.checked) return
      const csrf  = document.querySelector('meta[name="csrf-token"]').content
      const start = document.getElementById(`sched-start-${day}`).value
      const end   = document.getElementById(`sched-end-${day}`).value
      setSchedStatus(day, '...')
      const res = await fetch(`/admin/coaches/${scheduleCoachId}/schedule`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
        body: JSON.stringify({ dayOfWeek: day, startTime: start, endTime: end }),
      })
      setSchedStatus(day, res.ok ? 'Saved' : 'Error')
    }

    function setSchedStatus(day, text) {
      const el = document.getElementById(`sched-status-${day}`)
      if (el) el.textContent = text
    }

    document.getElementById('schedule-modal-close').addEventListener('click', closeScheduleModal)
    scheduleOverlay.addEventListener('click', e => { if (e.target === scheduleOverlay) closeScheduleModal() })

    document.querySelectorAll('.btn-schedule-coach').forEach(btn => {
      btn.addEventListener('click', () => {
        const schedules = JSON.parse(btn.dataset.schedules || '[]')
        openScheduleModal(btn.dataset.id, btn.dataset.name, schedules)
      })
    })

    // ── Court Modal ──
    const courtOverlay   = document.getElementById('court-modal-overlay')
    const courtModalTitle = document.getElementById('court-modal-title')
    const courtForm      = document.getElementById('court-form')
    const courtIdInput   = document.getElementById('court-id')
    const courtNameInput = document.getElementById('court-name')
    const courtPrice     = document.getElementById('court-price')
    const courtStatus    = document.getElementById('court-status')
    const courtSubmit    = document.getElementById('court-submit-btn')

    function openCourtModal({ id = '', name = '', price = '', status = 'available' } = {}) {
      courtIdInput.value   = id
      courtNameInput.value = name
      courtPrice.value     = price
      courtStatus.value    = status
      courtModalTitle.textContent = id ? 'Edit Court' : 'Add Court'
      courtSubmit.textContent     = id ? 'Save Changes' : 'Add Court'
      courtOverlay.style.display  = 'flex'
    }
    function closeCourtModal() {
      courtOverlay.style.display = 'none'
      courtForm.reset()
    }

    document.getElementById('btn-add-court').addEventListener('click', () => openCourtModal())
    document.getElementById('court-modal-close').addEventListener('click', closeCourtModal)
    document.getElementById('court-modal-cancel').addEventListener('click', closeCourtModal)
    courtOverlay.addEventListener('click', e => { if (e.target === courtOverlay) closeCourtModal() })

    document.querySelectorAll('.btn-edit-court').forEach(btn => {
      btn.addEventListener('click', () => openCourtModal({
        id:     btn.dataset.id,
        name:   btn.dataset.name,
        price:  btn.dataset.price,
        status: btn.dataset.status,
      }))
    })

    courtForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      const id   = courtIdInput.value
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      const body = {
        courtName:      courtNameInput.value,
        courtPricePerHr: parseFloat(courtPrice.value),
        courtStatus:    courtStatus.value,
      }
      courtSubmit.disabled = true
      try {
        const url    = id ? `/admin/courts/${id}` : '/admin/courts'
        const method = id ? 'PATCH' : 'POST'
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
          body: JSON.stringify(body),
        })
        if (res.ok) {
          closeCourtModal()
          location.reload()
        } else {
          const err = await res.json().catch(() => ({}))
          alert(err.message || 'Error saving court')
        }
      } finally {
        courtSubmit.disabled = false
      }
    })

    // ── Delete Court Modal ──
    const deleteOverlay    = document.getElementById('delete-modal-overlay')
    const deleteCourtName  = document.getElementById('delete-court-name')
    const deleteConfirmBtn = document.getElementById('delete-confirm-btn')
    let pendingDeleteId    = null

    function openDeleteModal(id, name) {
      pendingDeleteId = id
      deleteCourtName.textContent = name
      deleteOverlay.style.display = 'flex'
    }
    function closeDeleteModal() {
      deleteOverlay.style.display = 'none'
      pendingDeleteId = null
    }

    document.getElementById('delete-modal-close').addEventListener('click', closeDeleteModal)
    document.getElementById('delete-modal-cancel').addEventListener('click', closeDeleteModal)
    deleteOverlay.addEventListener('click', e => { if (e.target === deleteOverlay) closeDeleteModal() })

    document.querySelectorAll('.btn-delete-court').forEach(btn => {
      btn.addEventListener('click', () => openDeleteModal(btn.dataset.id, btn.dataset.name))
    })

    deleteConfirmBtn.addEventListener('click', async () => {
      if (!pendingDeleteId) return
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      deleteConfirmBtn.disabled = true
      try {
        const res = await fetch(`/admin/courts/${pendingDeleteId}`, {
          method: 'DELETE',
          headers: { 'X-CSRF-TOKEN': csrf },
        })
        if (res.ok) {
          closeDeleteModal()
          const row = document.getElementById(`court-row-${pendingDeleteId}`)
          if (row) row.remove()
        } else {
          const err = await res.json().catch(() => ({}))
          alert(err.message || 'Cannot delete court')
          closeDeleteModal()
        }
      } finally {
        deleteConfirmBtn.disabled = false
      }
    })

    coachForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      const id     = coachIdInput.value
      const csrf   = document.querySelector('meta[name="csrf-token"]').content
      const body   = {
        coachName:    coachName.value,
        coachLevelId: parseInt(coachLevel.value),
        coachStatus:  coachStatus.value,
      }
      coachSubmit.disabled = true
      try {
        const url    = id ? `/admin/coaches/${id}` : '/admin/coaches'
        const method = id ? 'PATCH' : 'POST'
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
          body: JSON.stringify(body),
        })
        if (res.ok) {
          closeCoachModal()
          location.reload()
        } else {
          const err = await res.json().catch(() => ({}))
          alert(err.message || 'Error saving coach')
        }
      } finally {
        coachSubmit.disabled = false
      }
    })

    // ── Customer Edit Modal ──
    const customerOverlay   = document.getElementById('customer-modal-overlay')
    const customerForm      = document.getElementById('customer-form')
    const customerIdInput   = document.getElementById('customer-id')
    const customerName      = document.getElementById('customer-name')
    const customerEmail     = document.getElementById('customer-email')
    const customerPhone     = document.getElementById('customer-phone')
    const customerType      = document.getElementById('customer-type')
    const customerTier      = document.getElementById('customer-tier')
    const customerUser      = document.getElementById('customer-user')
    const customerUserGroup = document.getElementById('customer-user-group')
    const customerSubmit    = document.getElementById('customer-submit-btn')

    function toggleUserGroup() {
      customerUserGroup.style.display = customerType.value === 'member' ? 'block' : 'none'
      if (customerType.value !== 'member') customerUser.value = ''
    }
    customerType.addEventListener('change', toggleUserGroup)

    function openCustomerModal({ id, name, email, phone, type, tier, user }) {
      customerIdInput.value = id
      customerName.value    = name
      customerEmail.value   = email
      customerPhone.value   = phone
      customerType.value    = type
      customerTier.value    = tier
      customerUser.value    = user
      toggleUserGroup()
      customerOverlay.style.display = 'flex'
    }
    function closeCustomerModal() {
      customerOverlay.style.display = 'none'
      customerForm.reset()
      customerUserGroup.style.display = 'none'
    }

    document.getElementById('customer-modal-close').addEventListener('click', closeCustomerModal)
    document.getElementById('customer-modal-cancel').addEventListener('click', closeCustomerModal)
    customerOverlay.addEventListener('click', e => { if (e.target === customerOverlay) closeCustomerModal() })

    document.querySelectorAll('.btn-edit-customer').forEach(btn => {
      btn.addEventListener('click', () => openCustomerModal({
        id:    btn.dataset.id,
        name:  btn.dataset.name,
        email: btn.dataset.email,
        phone: btn.dataset.phone,
        type:  btn.dataset.type,
        tier:  btn.dataset.tier,
        user:  btn.dataset.user,
      }))
    })

    customerForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      const id   = customerIdInput.value
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      const body = {
        customerName:  customerName.value,
        customerEmail: customerEmail.value || null,
        customerPhone: customerPhone.value || null,
        customerType:  customerType.value,
        tierId:        customerTier.value ? parseInt(customerTier.value) : null,
        userId:        customerUser.value  ? parseInt(customerUser.value)  : null,
      }
      customerSubmit.disabled = true
      try {
        const res = await fetch(`/admin/customers/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
          body: JSON.stringify(body),
        })
        if (res.ok) {
          closeCustomerModal()
          location.reload()
        } else {
          const err = await res.json().catch(() => ({}))
          alert(err.message || 'Error saving customer')
        }
      } finally {
        customerSubmit.disabled = false
      }
    })

    // ── User Modal ──
    const userOverlay      = document.getElementById('user-modal-overlay')
    const userModalTitle   = document.getElementById('user-modal-title')
    const userForm         = document.getElementById('user-form')
    const userIdInput      = document.getElementById('user-id')
    const userFullname     = document.getElementById('user-fullname')
    const userUsername     = document.getElementById('user-username')
    const userEmail        = document.getElementById('user-email')
    const userPassword     = document.getElementById('user-password')
    const userPasswordHint = document.getElementById('user-password-hint')
    const userRole         = document.getElementById('user-role')
    const userSubmit       = document.getElementById('user-submit-btn')

    function openUserModal({ id = '', fullname = '', username = '', email = '', role = 'member' } = {}) {
      userIdInput.value   = id
      userFullname.value  = fullname
      userUsername.value  = username
      userEmail.value     = email
      userRole.value      = role
      userPassword.value  = ''
      const isEdit = !!id
      userModalTitle.textContent  = isEdit ? 'Edit User' : 'Add User'
      userSubmit.textContent      = isEdit ? 'Save Changes' : 'Add User'
      userPasswordHint.style.display = isEdit ? 'block' : 'none'
      userPassword.required       = !isEdit
      userOverlay.style.display   = 'flex'
    }
    function closeUserModal() {
      userOverlay.style.display = 'none'
      userForm.reset()
    }

    document.getElementById('btn-add-user').addEventListener('click', () => openUserModal())
    document.getElementById('user-modal-close').addEventListener('click', closeUserModal)
    document.getElementById('user-modal-cancel').addEventListener('click', closeUserModal)
    userOverlay.addEventListener('click', e => { if (e.target === userOverlay) closeUserModal() })

    document.querySelectorAll('.btn-edit-user').forEach(btn => {
      btn.addEventListener('click', () => openUserModal({
        id:       btn.dataset.id,
        fullname: btn.dataset.fullname,
        username: btn.dataset.username,
        email:    btn.dataset.email,
        role:     btn.dataset.role,
      }))
    })

    userForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      const id   = userIdInput.value
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      const body = {
        fullName: userFullname.value || null,
        username: userUsername.value || null,
        email:    userEmail.value,
        role:     userRole.value,
      }
      if (userPassword.value) body.password = userPassword.value
      userSubmit.disabled = true
      try {
        const url    = id ? `/admin/users/${id}` : '/admin/users'
        const method = id ? 'PATCH' : 'POST'
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
          body: JSON.stringify(body),
        })
        if (res.ok) {
          closeUserModal()
          location.reload()
        } else {
          const err = await res.json().catch(() => ({}))
          alert(err.message || 'Error saving user')
        }
      } finally {
        userSubmit.disabled = false
      }
    })

    // ── User Delete Modal ──
    const userDeleteOverlay = document.getElementById('user-delete-overlay')
    const deleteUserName    = document.getElementById('delete-user-name')
    const userDeleteConfirm = document.getElementById('user-delete-confirm')
    let pendingUserDeleteId = null

    function openUserDeleteModal(id, name) {
      pendingUserDeleteId = id
      deleteUserName.textContent = name
      userDeleteOverlay.style.display = 'flex'
    }
    function closeUserDeleteModal() {
      userDeleteOverlay.style.display = 'none'
      pendingUserDeleteId = null
    }

    document.getElementById('user-delete-close').addEventListener('click', closeUserDeleteModal)
    document.getElementById('user-delete-cancel').addEventListener('click', closeUserDeleteModal)
    userDeleteOverlay.addEventListener('click', e => { if (e.target === userDeleteOverlay) closeUserDeleteModal() })

    document.querySelectorAll('.btn-delete-user').forEach(btn => {
      btn.addEventListener('click', () => openUserDeleteModal(btn.dataset.id, btn.dataset.name))
    })

    userDeleteConfirm.addEventListener('click', async () => {
      if (!pendingUserDeleteId) return
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      userDeleteConfirm.disabled = true
      try {
        const res = await fetch(`/admin/users/${pendingUserDeleteId}`, {
          method: 'DELETE',
          headers: { 'X-CSRF-TOKEN': csrf },
        })
        if (res.ok) {
          closeUserDeleteModal()
          const row = document.getElementById(`user-row-${pendingUserDeleteId}`)
          if (row) row.remove()
        } else {
          const err = await res.json().catch(() => ({}))
          alert(err.message || 'Cannot delete user')
          closeUserDeleteModal()
        }
      } finally {
        userDeleteConfirm.disabled = false
      }
    })

    // ── Tier Modal ──
    const tierOverlay    = document.getElementById('tier-modal-overlay')
    const tierModalTitle = document.getElementById('tier-modal-title')
    const tierForm       = document.getElementById('tier-form')
    const tierIdInput    = document.getElementById('tier-id')
    const tierDesc       = document.getElementById('tier-desc')
    const tierHours      = document.getElementById('tier-hours')
    const tierDiscount   = document.getElementById('tier-discount')
    const tierSubmit     = document.getElementById('tier-submit-btn')

    function openTierModal({ id = '', desc = '', hours = '', discount = '' } = {}) {
      tierIdInput.value  = id
      tierDesc.value     = desc
      tierHours.value    = hours
      tierDiscount.value = discount
      tierModalTitle.textContent = id ? 'Edit Tier' : 'Add Tier'
      tierSubmit.textContent     = id ? 'Save Changes' : 'Add Tier'
      tierOverlay.style.display  = 'flex'
    }
    function closeTierModal() {
      tierOverlay.style.display = 'none'
      tierForm.reset()
    }

    document.getElementById('btn-add-tier').addEventListener('click', () => openTierModal())
    document.getElementById('tier-modal-close').addEventListener('click', closeTierModal)
    document.getElementById('tier-modal-cancel').addEventListener('click', closeTierModal)
    tierOverlay.addEventListener('click', e => { if (e.target === tierOverlay) closeTierModal() })

    document.querySelectorAll('.btn-edit-tier').forEach(btn => {
      btn.addEventListener('click', () => openTierModal({
        id:       btn.dataset.id,
        desc:     btn.dataset.desc,
        hours:    btn.dataset.hours,
        discount: btn.dataset.discount,
      }))
    })

    tierForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      const id   = tierIdInput.value
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      const body = {
        tierDesc:     tierDesc.value,
        minHours:     parseInt(tierHours.value),
        tierDiscount: parseInt(tierDiscount.value),
      }
      tierSubmit.disabled = true
      try {
        const url    = id ? `/admin/tiers/${id}` : '/admin/tiers'
        const method = id ? 'PATCH' : 'POST'
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
          body: JSON.stringify(body),
        })
        if (res.ok) {
          closeTierModal()
          location.reload()
        } else {
          const err = await res.json().catch(() => ({}))
          alert(err.message || 'Error saving tier')
        }
      } finally {
        tierSubmit.disabled = false
      }
    })

    // ── Delete Tier Modal ──
    const tierDeleteOverlay = document.getElementById('tier-delete-overlay')
    const deleteTierDesc    = document.getElementById('delete-tier-desc')
    const tierDeleteConfirm = document.getElementById('tier-delete-confirm')
    let pendingTierDeleteId = null

    function openTierDeleteModal(id, desc) {
      pendingTierDeleteId = id
      deleteTierDesc.textContent = desc
      tierDeleteOverlay.style.display = 'flex'
    }
    function closeTierDeleteModal() {
      tierDeleteOverlay.style.display = 'none'
      pendingTierDeleteId = null
    }

    document.getElementById('tier-delete-close').addEventListener('click', closeTierDeleteModal)
    document.getElementById('tier-delete-cancel').addEventListener('click', closeTierDeleteModal)
    tierDeleteOverlay.addEventListener('click', e => { if (e.target === tierDeleteOverlay) closeTierDeleteModal() })

    document.querySelectorAll('.btn-delete-tier').forEach(btn => {
      btn.addEventListener('click', () => openTierDeleteModal(btn.dataset.id, btn.dataset.desc))
    })

    tierDeleteConfirm.addEventListener('click', async () => {
      if (!pendingTierDeleteId) return
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      tierDeleteConfirm.disabled = true
      try {
        const res = await fetch(`/admin/tiers/${pendingTierDeleteId}`, {
          method: 'DELETE',
          headers: { 'X-CSRF-TOKEN': csrf },
        })
        if (res.ok) {
          closeTierDeleteModal()
          const row = document.getElementById(`tier-row-${pendingTierDeleteId}`)
          if (row) row.remove()
        } else {
          const err = await res.json().catch(() => ({}))
          alert(err.message || 'Cannot delete tier')
          closeTierDeleteModal()
        }
      } finally {
        tierDeleteConfirm.disabled = false
      }
    })

    // Refresh ทุกครั้งที่กด confirm/cancel
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('[data-action]')
      if (!btn) return
      const action = btn.dataset.action
      const id     = btn.dataset.id
      if (!['confirmed', 'cancelled'].includes(action)) return

      btn.disabled = true
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      try {
        await fetch(`/bookings/${id}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
          body: JSON.stringify({ status: action }),
        })
        // อัปเดต badge ใน row
        const row  = btn.closest('tr')
        const badge = row.querySelector('.badge')
        badge.className = `badge badge-${action}`
        badge.textContent = action
        // ซ่อน action buttons
        row.querySelector('.action-btns').remove()
      } finally {
        btn.disabled = false
        refreshStats()
      }
    })
  </script>
</body>
</html>
