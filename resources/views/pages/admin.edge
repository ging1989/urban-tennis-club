                      </span>
                    </td>
                    <td class="td-muted">
                      @if(u.role === 'member' && u.customer && u.customer.tier)
                        {{ u.customer.tier.tierDesc }}
                      @elseif(u.role === 'member')
                        <span style="color:var(--muted)">—</span>
                      @else
                        <span style="color:var(--muted)">—</span>
                      @end
                    </td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-action btn-edit btn-edit-user"
                          data-id="{{ u.id }}"
