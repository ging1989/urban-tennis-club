    // Refresh ทุกครั้งที่กด confirm/cancel
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('[data-action]')
      if (!btn) return
      const action = btn.dataset.action
      const id     = btn.dataset.id
      if (!['confirmed', 'cancelled'].includes(action)) return

      btn.disabled = true
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      try {
        await fetch(`/bookings/${id}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
          body: JSON.stringify({ status: action }),
        })
        // อัปเดต badge ใน row
        const row  = btn.closest('tr')
        const badge = row.querySelector('.badge')
        badge.className = `badge badge-${action}`
        badge.textContent = action
        // ซ่อน action buttons
        row.querySelector('.action-btns').remove()
      } finally {
        btn.disabled = false
        refreshStats()
      }
    })

    // ── Report Filter ──────────────────────────────────────
    ;(function initReportFilter() {
      const courtSel = document.getElementById('rpt-court')
      const rows = Array.from(document.querySelectorAll('#recent-bookings-tbody tr'))

      // populate court dropdown from row data
      const courts = [...new Set(rows.map(r => r.dataset.court).filter(Boolean))].sort()
      courts.forEach(name => {
        const opt = document.createElement('option')
        opt.value = name
        opt.textContent = name
        courtSel.appendChild(opt)
      })
    })()

    function applyReportFilter() {
      const from  = document.getElementById('rpt-date-from').value
      const to    = document.getElementById('rpt-date-to').value
      const court = document.getElementById('rpt-court').value
      const type  = document.getElementById('rpt-type').value

      let visible = 0
      document.querySelectorAll('#recent-bookings-tbody tr').forEach(row => {
        const date = row.dataset.date || ''
        const matchFrom  = !from  || date >= from
        const matchTo    = !to    || date <= to
        const matchCourt = !court || row.dataset.court === court
        const matchType  = !type  || row.dataset.type === type
        const show = matchFrom && matchTo && matchCourt && matchType
        row.style.display = show ? '' : 'none'
        if (show) visible++
      })

      const total = document.querySelectorAll('#recent-bookings-tbody tr').length
      document.getElementById('rpt-count').textContent =
        visible === total ? '' : `Showing ${visible} of ${total} bookings`
    }

    function clearReportFilter() {
      document.getElementById('rpt-date-from').value = ''
      document.getElementById('rpt-date-to').value   = ''
      document.getElementById('rpt-court').value     = ''
      document.getElementById('rpt-type').value      = ''
      document.querySelectorAll('#recent-bookings-tbody tr').forEach(r => r.style.display = '')
      document.getElementById('rpt-count').textContent = ''
    }

    function exportReportCsv() {
      const headers = ['ID', 'Customer', 'Court', 'Date', 'Time', 'Court Price', 'Coach Price', 'Total', 'Payment', 'Status', 'Customer Type']
      const rows = Array.from(document.querySelectorAll('#recent-bookings-tbody tr'))
        .filter(r => r.style.display !== 'none')
        .map(r => {
          const cells = Array.from(r.querySelectorAll('td')).map(td => {
            const text = td.textContent.trim().replace(/\s+/g, ' ')
            // wrap in quotes if contains comma, quote, or newline
            return /[",\n]/.test(text) ? `"${text.replace(/"/g, '""')}"` : text
          })
          return cells.join(',')
        })

      const csv = [headers.join(','), ...rows].join('\r\n')
      const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' })
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      const from = document.getElementById('rpt-date-from').value
      const to   = document.getElementById('rpt-date-to').value
      const datePart = from && to ? `_${from}_to_${to}` : from ? `_from_${from}` : to ? `_to_${to}` : ''
      a.href = url
      a.download = `bookings_report${datePart}.csv`
      a.click()
      URL.revokeObjectURL(url)
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
</body>
</html>
