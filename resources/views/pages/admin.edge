<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Urban Tennis Club</title>
  <meta name="csrf-token" content="{{ csrfToken }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

  {{-- ── SIDEBAR ── --}}
  <aside class="sidebar">
    <div class="sidebar-logo">
      <span class="logo-icon">🎾</span>
      <span class="logo-text">Urban Tennis</span>
    </div>

    <div class="nav-label">NAVIGATION</div>

    <nav class="sidebar-nav">
      <a href="#" class="nav-item active" data-section="dashboard">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        </span>
        Dashboard
      </a>
      {{-- Reports group --}}
      <div id="nav-reports-toggle" class="nav-item" style="cursor:pointer;display:flex;align-items:center;" onclick="toggleReportsMenu()">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </span>
        <span style="flex:1;">Reports</span>
        <svg id="reports-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="transition:transform .2s;margin-right:4px;"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div id="reports-submenu" style="display:none;">
        <a href="#" class="nav-sub-rpt" data-sub="overview" onclick="activateReportSub('overview',event)"
           style="display:flex;align-items:center;gap:8px;padding:7px 12px 7px 44px;font-size:13px;color:var(--sidebar-txt);text-decoration:none;border-radius:6px;transition:background .15s;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Overview
        </a>
        <a href="#" class="nav-sub-rpt" data-sub="coach" onclick="activateReportSub('coach',event)"
           style="display:flex;align-items:center;gap:8px;padding:7px 12px 7px 44px;font-size:13px;color:var(--sidebar-txt);text-decoration:none;border-radius:6px;transition:background .15s;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Coach
        </a>
        <a href="#" class="nav-sub-rpt" data-sub="court" onclick="activateReportSub('court',event)"
           style="display:flex;align-items:center;gap:8px;padding:7px 12px 7px 44px;font-size:13px;color:var(--sidebar-txt);text-decoration:none;border-radius:6px;transition:background .15s;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
          Court
        </a>
        <a href="#" class="nav-sub-rpt" data-sub="customer" onclick="activateReportSub('customer',event)"
           style="display:flex;align-items:center;gap:8px;padding:7px 12px 7px 44px;font-size:13px;color:var(--sidebar-txt);text-decoration:none;border-radius:6px;transition:background .15s;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Customer
        </a>
      </div>
      <a href="#" class="nav-item" data-section="courts">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
        </span>
        Court Management
      </a>
      <a href="#" class="nav-item" data-section="coaches">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </span>
        Coach Management
      </a>
      <a href="#" class="nav-item" data-section="members">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
        Customer Management
      </a>
      <a href="#" class="nav-item" data-section="tiers">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
        Tier Management
      </a>
      <a href="#" class="nav-item" data-section="users">
        <span class="nav-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </span>
        User Management
      </a>
    </nav>

    <div class="sidebar-footer">
      <a href="/" class="footer-link">← Back to Site</a>
    </div>
  </aside>

  {{-- ── MAIN ── --}}
  <div class="admin-main">

    {{-- Topbar --}}
    <header class="topbar">
      <div class="topbar-breadcrumb">
        <span class="breadcrumb-home">Home</span>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current" id="breadcrumb-current">Dashboard</span>
      </div>
      <div class="topbar-right">
        <span class="topbar-user">{{ auth.user ? (auth.user.fullName ?? auth.user.email) : '' }}</span>
        <form action="{{ route('admin.logout') }}" method="post" style="display:inline">
          {{ csrfField() }}
          <button type="submit" class="btn-logout">Logout</button>
        </form>
      </div>
    </header>

    <div class="admin-content">

      {{-- ══ DASHBOARD ══ --}}
      <section id="section-dashboard" class="admin-section active">
        <div class="section-header">
          <h1 class="section-title">Dashboard</h1>
        </div>

        {{-- Stat Cards --}}
        <div class="stat-grid">

          {{-- Hero card: Today's Revenue --}}
          <div class="stat-card stat-card--hero">
            <div class="stat-hero-label">Today's Revenue</div>
            <div class="stat-hero-value" id="kpi-revenue"><span class="hero-currency">฿</span>{{ stats.todayRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</div>
            <div class="stat-hero-trend">Non-cancelled bookings</div>
          </div>

          {{-- Other cards --}}
          <div class="stat-card stat-card--center">
            <div class="stat-label">Bookings</div>
            <div class="stat-value" id="kpi-bookings">{{ stats.todayBookings }}</div>
            <div class="stat-trend">Today</div>
          </div>
          <div class="stat-card stat-card--center">
            <div class="stat-label">Customers</div>
            <div class="stat-value amber" id="kpi-customers">{{ stats.todayCustomers }}</div>
            <div class="stat-trend">Today</div>
          </div>
          <div class="stat-card stat-card--center">
            <div class="stat-label">Available Courts</div>
            <div class="stat-value" style="color:var(--red)" id="kpi-courts">{{ stats.availableCourts }}</div>
            <div class="stat-trend">Today</div>
          </div>
          <div class="stat-card stat-card--center">
            <div class="stat-label">Coach Revenue</div>
            <div class="stat-value" style="color:var(--blue)" id="kpi-coach-revenue">฿{{ stats.todayCoachRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</div>
            <div class="stat-trend">Today</div>
          </div>
        </div>

        {{-- Charts Row --}}
        <div class="two-col">
          <div class="panel">
            <div class="panel-title">Bookings: Last 7 days</div>
            <div class="bar-chart">
              @each(day in last7)
                <div class="bar-col">
                  <div class="bar-count">{{ day.count }}</div>
                  <div
                    class="bar {{ day.count === 0 ? 'zero' : '' }}"
                    style="height: {{ day.count === 0 ? '4px' : 'calc(' + day.count + ' / ' + Math.max(...last7.map(d => d.count), 1) + ' * 80px)' }}"
                  ></div>
                  <div class="bar-label">{{ day.date.slice(5) }}</div>
                </div>
              @end
            </div>
          </div>

          <div class="panel">
            <div class="panel-title">Booking Status: Today</div>
            <div class="status-row">
              <span class="status-dot dot-confirmed"></span>
              <span class="status-name">Confirmed</span>
              <div class="status-bar-wrap">
                <div class="status-bar-fill" id="status-confirmed-bar" style="width:{{ (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) > 0 ? (stats.confirmedCount / (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) * 100).toFixed(1) : 0 }}%;background:var(--green);"></div>
              </div>
              <span class="status-count" id="status-confirmed-count">{{ stats.confirmedCount }}</span>
            </div>
            <div class="status-row">
              <span class="status-dot dot-pending"></span>
              <span class="status-name">Pending</span>
              <div class="status-bar-wrap">
                <div class="status-bar-fill" id="status-pending-bar" style="width:{{ (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) > 0 ? (stats.pendingCount / (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) * 100).toFixed(1) : 0 }}%;background:var(--amber);"></div>
              </div>
              <span class="status-count" id="status-pending-count">{{ stats.pendingCount }}</span>
            </div>
            <div class="status-row">
              <span class="status-dot dot-cancelled"></span>
              <span class="status-name">Cancelled</span>
              <div class="status-bar-wrap">
                <div class="status-bar-fill" id="status-cancelled-bar" style="width:{{ (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) > 0 ? (stats.cancelledCount / (stats.pendingCount + stats.confirmedCount + stats.cancelledCount) * 100).toFixed(1) : 0 }}%;background:var(--red);"></div>
              </div>
              <span class="status-count" id="status-cancelled-count">{{ stats.cancelledCount }}</span>
            </div>
          </div>
        </div>

        {{-- Coach Charts --}}
        <div class="two-col" style="margin-bottom:24px">

          {{-- Line chart: coach revenue last 7 days --}}
          <div class="panel">
            <div class="panel-title">Coach Revenue: Last 7 days</div>
            <div class="line-chart-wrap">
              <svg class="line-chart-svg" viewBox="0 0 420 90" preserveAspectRatio="none"
                data-points="{{ last7CoachRevenue.map(d => d.revenue).join(',') }}">
                <defs>
                  <linearGradient id="coachGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#2ea043" stop-opacity="0.25"/>
                    <stop offset="100%" stop-color="#2ea043" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path class="line-area" fill="url(#coachGrad)"/>
                <path class="line-path" fill="none" stroke="#2ea043" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
              </svg>
              <div class="line-labels">
                @each(day in last7CoachRevenue)
                  <span>{{ day.date.slice(5) }}</span>
                @end
              </div>
            </div>
          </div>

          {{-- Bar chart: coach revenue today per coach --}}
          <div class="panel">
            <div class="panel-title">Coach Revenue: Today</div>
            @if(coachRevenueToday.length === 0)
              <div style="color:var(--muted);font-size:13px;padding:16px 0;text-align:center">No coach bookings today</div>
            @else
              <div class="bar-chart" style="height:110px">
                @each(c in coachRevenueToday)
                  <div class="bar-col">
                    <div class="bar-count" style="font-size:9px">฿{{ c.revenue.toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</div>
                    <div
                      class="bar bar--coach"
                      style="height: calc({{ c.revenue }} / {{ Math.max(...coachRevenueToday.map(x => x.revenue), 1) }} * 80px)"
                    ></div>
                    <div class="bar-label">{{ c.name }}</div>
                  </div>
                @end
              </div>
            @end
          </div>

        </div>


      </section>

      {{-- ══ REPORTS ══ --}}
      <section id="section-report" class="admin-section">
        <div class="section-header" style="display:flex;align-items:center;justify-content:space-between;">
          <h1 class="section-title">Reports</h1>
          <div style="display:flex;gap:4px;background:#f1f5f9;padding:4px;border-radius:8px;">
            <button id="rpt-tab-overview" onclick="switchReportSub('overview')"
              style="padding:6px 16px;border:none;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;background:#fff;color:#1e293b;box-shadow:0 1px 3px rgba(0,0,0,.1);">
              Overview
            </button>
            <button id="rpt-tab-coach" onclick="switchReportSub('coach')"
              style="padding:6px 16px;border:none;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;background:transparent;color:#64748b;">
              Coach
            </button>
            <button id="rpt-tab-court" onclick="switchReportSub('court')"
              style="padding:6px 16px;border:none;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;background:transparent;color:#64748b;">
              Court
            </button>
            <button id="rpt-tab-customer" onclick="switchReportSub('customer')"
              style="padding:6px 16px;border:none;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;background:transparent;color:#64748b;">
              Customer
            </button>
          </div>
        </div>

        {{-- ── Overview sub-section ── --}}
        <div id="rpt-sub-overview">

        {{-- Filter bar --}}
        <div class="panel" style="margin-bottom:16px;">
          <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
            <div>
              <div class="form-label">From</div>
              <input type="date" id="rpt-date-from" class="form-input" style="width:148px;">
            </div>
            <div>
              <div class="form-label">To</div>
              <input type="date" id="rpt-date-to" class="form-input" style="width:148px;">
            </div>
            <div>
              <div class="form-label">Court</div>
              <select id="rpt-court" class="form-input" style="width:160px;">
                <option value="">All Courts</option>
              </select>
            </div>
            <div>
              <div class="form-label">Type</div>
              <select id="rpt-type" class="form-input" style="width:130px;">
                <option value="">All</option>
                <option value="member">Member</option>
                <option value="guest">Guest</option>
              </select>
            </div>
            <div style="display:flex;gap:8px;">
              <button class="btn-primary" onclick="applyReportFilter()">Apply</button>
              <button class="btn-secondary" onclick="clearReportFilter()">Clear</button>
              <button class="btn-secondary" onclick="exportReportCsv()" style="display:flex;align-items:center;gap:6px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export CSV
              </button>
            </div>
          </div>
          <div id="rpt-count" style="margin-top:10px;font-size:12.5px;color:var(--muted);"></div>
        </div>

        <div class="panel">
          <div class="panel-title">Recent Bookings (50 latest)</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Customer</th>
                  <th>Court</th>
                  <th>Date</th>
                  <th>Time</th>
                  <th>Court Price</th>
                  <th>Coach Price</th>
                  <th>Total</th>
                  <th>Payment</th>
                  <th>Status</th>
                  <th>Customer Type</th>
                </tr>
              </thead>
              <tbody id="recent-bookings-tbody">
                @each(b in recentBookings)
                  <tr
                    data-date="{{ b.bookingDate.toISODate() }}"
                    data-court="{{ b.court ? b.court.courtName : '' }}"
                    data-type="{{ b.customer ? b.customer.customerType : '' }}"
                  >
                    <td class="td-muted">#{{ b.bookingId }}</td>
                    <td>{{ b.customer ? b.customer.customerName : '—' }}</td>
                    <td>{{ b.court ? b.court.courtName : '—' }}</td>
                    <td class="td-muted">{{ b.bookingDate.toFormat('dd-MM-yyyy') }}</td>
                    <td class="td-muted">{{ b.bookingStart }} – {{ b.bookingEnd }}</td>
                    <td class="td-muted">฿{{ parseFloat(b.bookingCourtPrice || 0).toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</td>
                    <td class="td-muted">{{ b.bookingCoachPrice ? '฿' + parseFloat(b.bookingCoachPrice).toLocaleString('th-TH', { maximumFractionDigits: 0 }) : '—' }}</td>
                    <td>฿{{ parseFloat(b.totalPrice).toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</td>
                    <td class="td-muted">{{ b.payment ? b.payment.paymentMethod : '—' }}</td>
                    <td><span class="badge badge-{{ b.bookingStatus }}">{{ b.bookingStatus }}</span></td>
                    <td class="td-muted">{{ b.customer ? b.customer.customerType : '—' }}</td>
                  </tr>
                @end
              </tbody>
            </table>
          </div>
        </div>

        </div>{{-- end #rpt-sub-overview --}}

        {{-- ── Coach sub-section ── --}}
        <div id="rpt-sub-coach" style="display:none;">

          {{-- Filter --}}
          <div class="panel" style="margin-bottom:16px;">
            <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
              <div>
                <div class="form-label">From</div>
                <input type="date" id="coach-rpt-from" class="form-input" style="width:148px;">
              </div>
              <div>
                <div class="form-label">To</div>
                <input type="date" id="coach-rpt-to" class="form-input" style="width:148px;">
              </div>
              <div style="display:flex;gap:8px;">
                <button class="btn-primary" onclick="applyCoachReport()">Apply</button>
                <button class="btn-secondary" onclick="clearCoachReport()">Clear</button>
              </div>
            </div>
          </div>

          {{-- Table + Chart --}}
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

            <div class="panel">
              <div class="panel-title" id="coach-rpt-title">Coach Revenue (All Time)</div>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Coach</th>
                      <th style="text-align:right;">Sessions</th>
                      <th style="text-align:right;">Hours</th>
                      <th style="text-align:right;">Revenue</th>
                      <th style="text-align:right;">Avg/Session</th>
                    </tr>
                  </thead>
                  <tbody id="coach-rpt-tbody"></tbody>
                  <tfoot>
                    <tr style="font-weight:700;border-top:2px solid #e2e8f0;">
                      <td>Total</td>
                      <td style="text-align:right;" id="coach-rpt-total-sessions">—</td>
                      <td></td>
                      <td style="text-align:right;" id="coach-rpt-total-revenue">—</td>
                      <td></td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>

            <div class="panel" style="display:flex;flex-direction:column;">
              <div class="panel-title">Revenue by Coach</div>
              <div style="flex:1;position:relative;min-height:200px;">
                <canvas id="coach-rpt-chart"></canvas>
              </div>
            </div>

          </div>
        </div>{{-- end #rpt-sub-coach --}}

        {{-- ── Court sub-section ── --}}
        <div id="rpt-sub-court" style="display:none;">

          {{-- Filter --}}
          <div class="panel" style="margin-bottom:16px;">
            <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
              <div>
                <div class="form-label">From</div>
                <input type="date" id="court-rpt-from" class="form-input" style="width:148px;">
              </div>
              <div>
                <div class="form-label">To</div>
                <input type="date" id="court-rpt-to" class="form-input" style="width:148px;">
              </div>
              <div style="display:flex;gap:8px;">
                <button class="btn-primary" onclick="applyCourtReport()">Apply</button>
                <button class="btn-secondary" onclick="clearCourtReport()">Clear</button>
              </div>
            </div>
          </div>

          {{-- Table + Chart --}}
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

            <div class="panel">
              <div class="panel-title" id="court-rpt-title">Court Revenue (All Time)</div>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Court</th>
                      <th style="text-align:right;">Revenue</th>
                    </tr>
                  </thead>
                  <tbody id="court-rpt-tbody"></tbody>
                  <tfoot>
                    <tr style="font-weight:700;border-top:2px solid #e2e8f0;">
                      <td>Total</td>
                      <td style="text-align:right;" id="court-rpt-total">—</td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>

            <div class="panel" style="display:flex;flex-direction:column;">
              <div class="panel-title">Revenue by Court</div>
              <div style="flex:1;position:relative;min-height:200px;">
                <canvas id="court-rpt-chart"></canvas>
              </div>
            </div>

          </div>

        </div>{{-- end #rpt-sub-court --}}

        {{-- ── Customer sub-section ── --}}
        <div id="rpt-sub-customer" style="display:none;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

            <div class="panel">
              <div class="panel-title">Customer Revenue Summary</div>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Customer</th>
                      <th style="text-align:right;">Court Price</th>
                      <th style="text-align:right;">Coach Price</th>
                      <th style="text-align:right;">Total</th>
                      <th>Member Type</th>
                      <th style="text-align:right;">Bookings</th>
                    </tr>
                  </thead>
                  <tbody>
                    @each(c in customerReportData)
                      <tr>
                        <td style="font-weight:600;">{{ c.customerName }}</td>
                        <td style="text-align:right;" class="td-muted">฿{{ c.courtPrice.toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</td>
                        <td style="text-align:right;" class="td-muted">{{ c.coachPrice > 0 ? '฿' + c.coachPrice.toLocaleString('th-TH', { maximumFractionDigits: 0 }) : '—' }}</td>
                        <td style="text-align:right;font-weight:600;">฿{{ c.total.toLocaleString('th-TH', { maximumFractionDigits: 0 }) }}</td>
                        <td><span class="badge {{ c.customerType === 'member' ? 'badge-confirmed' : 'badge-pending' }}">{{ c.customerType }}</span></td>
                        <td style="text-align:right;" class="td-muted">{{ c.bookings }}</td>
                      </tr>
                    @end
                    @if(customerReportData.length === 0)
                      <tr><td colspan="6" style="text-align:center;color:var(--muted);padding:24px;">No data</td></tr>
                    @end
                  </tbody>
                </table>
              </div>
            </div>

            <div class="panel" style="display:flex;flex-direction:column;">
              <div class="panel-title">Top 5 Customers by Revenue</div>
              <div style="flex:1;position:relative;min-height:200px;">
                <canvas id="customer-rpt-chart"></canvas>
              </div>
            </div>

          </div>
        </div>{{-- end #rpt-sub-customer --}}

      </section>

      {{-- ══ COURT MANAGEMENT ══ --}}
