  <style>
    #toast-container { position:fixed; bottom:24px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; }
    .toast {
      background:#1e293b; color:#fff; padding:12px 20px; border-radius:10px;
      font-size:13.5px; font-weight:500; box-shadow:0 4px 16px rgba(0,0,0,.25);
      display:flex; align-items:center; gap:10px;
      animation: toastIn .25s ease;
    }
    .toast.success { border-left:4px solid #16a34a; }
    .toast.error   { border-left:4px solid #dc2626; }
    @keyframes toastIn { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
  </style>

  <div id="toast-container"></div>

  <script>
    function showToast(msg, type = 'success', duration = 3000) {
      const container = document.getElementById('toast-container')
      const el = document.createElement('div')
      el.className = `toast ${type}`
      el.innerHTML = (type === 'success' ? '✓ ' : '✕ ') + msg
      container.appendChild(el)
      setTimeout(() => el.remove(), duration)
    }

    // ── Tab switching ──
    const navItems = document.querySelectorAll('.nav-item')
    const sections = document.querySelectorAll('.admin-section')
    const breadcrumb = document.getElementById('breadcrumb-current')

    function activateSection(target) {
      // Skip if target is handled by reports sub-menu
      if (target === 'report') {
        navItems.forEach(i => i.classList.remove('active'))
        sections.forEach(s => s.classList.remove('active'))
        document.getElementById('nav-reports-toggle').classList.add('active')
        document.getElementById('section-report').classList.add('active')
        document.getElementById('reports-submenu').style.display = 'block'
        document.getElementById('reports-chevron').style.transform = 'rotate(180deg)'
        breadcrumb.textContent = 'Reports'
        return
      }
      const item = document.querySelector(`.nav-item[data-section="${target}"]`)
      if (!item) return
      navItems.forEach(i => i.classList.remove('active'))
      sections.forEach(s => s.classList.remove('active'))
      item.classList.add('active')
      document.getElementById('section-' + target).classList.add('active')
      breadcrumb.textContent = item.textContent.trim()
    }

    navItems.forEach(item => {
      item.addEventListener('click', e => {
        e.preventDefault()
        const target = item.dataset.section
        if (!target) return
        activateSection(target)
        history.replaceState(null, '', '#' + target)
      })
    })

    // ── Reports sub-menu ──
    function toggleReportsMenu() {
      const menu    = document.getElementById('reports-submenu')
      const chevron = document.getElementById('reports-chevron')
      const isOpen  = menu.style.display !== 'none'
      menu.style.display = isOpen ? 'none' : 'block'
      chevron.style.transform = isOpen ? '' : 'rotate(180deg)'
      if (!isOpen) {
        // activate report section when opening
        activateSection('report')
      }
    }

    function activateReportSub(sub, e) {
      if (e) e.preventDefault()
      activateSection('report')
      switchReportSub(sub)
      history.replaceState(null, '', '#report-' + sub)
    }

    function switchReportSub(sub) {
      const subs = ['overview', 'coach', 'court', 'customer']
      subs.forEach(s => {
        document.getElementById('rpt-sub-' + s).style.display = s === sub ? '' : 'none'
        const btn = document.getElementById('rpt-tab-' + s)
        const active = s === sub
        btn.style.background = active ? '#fff' : 'transparent'
        btn.style.color      = active ? '#1e293b' : '#64748b'
        btn.style.boxShadow  = active ? '0 1px 3px rgba(0,0,0,.1)' : 'none'
      })
      document.querySelectorAll('.nav-sub-rpt').forEach(a => {
        const active = a.dataset.sub === sub
        a.style.background = active ? 'rgba(255,255,255,.1)' : ''
        a.style.color      = active ? '#fff' : ''
      })
      if (sub === 'coach' && !window._coachChartsInited) initCoachCharts()
      if (sub === 'customer' && !window._customerChartInited) initCustomerChart()
      if (sub === 'court') {
        const now = new Date()
        const y = now.getFullYear()
        const m = String(now.getMonth() + 1).padStart(2, '0')
        const lastDay = new Date(y, now.getMonth() + 1, 0).getDate()
        const fromEl = document.getElementById('court-rpt-from')
        const toEl   = document.getElementById('court-rpt-to')
        if (!fromEl.value) fromEl.value = `${y}-${m}-01`
        if (!toEl.value)   toEl.value   = `${y}-${m}-${lastDay}`
        renderCourtReport(fromEl.value, toEl.value)
      }
    }

    // ── Customer Chart (lazy) ──
    function initCustomerChart() {
      window._customerChartInited = true
      const data   = {{{ JSON.stringify(customerReportData) }}}
      const top5   = data.slice(0, 5)
      const labels = top5.map(c => c.customerName)
      const values = top5.map(c => c.total)
      const _pal   = ['#2563eb','#16a34a','#d97706','#dc2626','#7c3aed']

      new Chart(document.getElementById('customer-rpt-chart'), {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Total Revenue',
            data: values,
            backgroundColor: _pal.map(c => c + 'b3'),
            borderColor: _pal,
            borderWidth: 1,
            borderRadius: 4,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, grid: { color: '#f1f5f9' },
              ticks: { callback: v => '฿' + v.toLocaleString('th-TH') } },
            x: { grid: { display: false } },
          },
        },
      })
    }

    // ── Court Report ──
    const _courtBookingData = {{{ JSON.stringify(courtBookingData) }}}

    let _courtChart = null

    function renderCourtReport(from, to) {
      let rows = _courtBookingData
      if (from) rows = rows.filter(r => r.date >= from)
      if (to)   rows = rows.filter(r => r.date <= to)

      const map = {}
      const idMap = {}
      rows.forEach(r => {
        map[r.courtName]   = (map[r.courtName] || 0) + r.revenue
        idMap[r.courtName] = r.courtId
      })

      const tbody   = document.getElementById('court-rpt-tbody')
      const totalEl = document.getElementById('court-rpt-total')
      const titleEl = document.getElementById('court-rpt-title')

      const entries = Object.entries(map).sort((a, b) => (idMap[a[0]] || 0) - (idMap[b[0]] || 0))
      const total   = entries.reduce((s, [, v]) => s + v, 0)

      // ── Table ──
      if (entries.length === 0) {
        tbody.innerHTML = '<tr><td colspan="2" style="text-align:center;color:var(--muted);padding:20px;">No data</td></tr>'
        totalEl.textContent = '—'
      } else {
        tbody.innerHTML = entries.map(([name, rev]) =>
          `<tr>
            <td>${name}</td>
            <td style="text-align:right;font-weight:600;">฿${rev.toLocaleString('th-TH', { maximumFractionDigits: 0 })}</td>
          </tr>`
        ).join('')
        totalEl.textContent = '฿' + total.toLocaleString('th-TH', { maximumFractionDigits: 0 })
      }

      titleEl.textContent = from || to
        ? `Court Revenue (${from || '—'} → ${to || '—'})`
        : 'Court Revenue (All Time)'

      // ── Bar Chart ──
      const labels = entries.map(([name]) => name)
      const values = entries.map(([, rev]) => rev)
      const _palette = ['#2563eb','#16a34a','#d97706','#dc2626','#7c3aed','#0891b2','#db2777','#65a30d']
      function courtColor(name) {
        let h = 0
        for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) & 0xffff
        return _palette[h % _palette.length]
      }

      if (_courtChart) {
        _courtChart.data.labels   = labels
        _courtChart.data.datasets[0].data = values
        _courtChart.data.datasets[0].backgroundColor = labels.map(n => courtColor(n) + 'b3')
        _courtChart.data.datasets[0].borderColor     = labels.map(n => courtColor(n))
        _courtChart.update()
      } else {
        _courtChart = new Chart(document.getElementById('court-rpt-chart'), {
          type: 'bar',
          data: {
            labels,
            datasets: [{
              label: 'Revenue',
              data: values,
              backgroundColor: labels.map(n => courtColor(n) + 'b3'),
              borderColor:     labels.map(n => courtColor(n)),
              borderWidth: 1,
              borderRadius: 4,
            }],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, grid: { color: '#f1f5f9' },
                ticks: { callback: v => '฿' + v.toLocaleString('th-TH') } },
              x: { grid: { display: false } },
            },
          },
        })
      }
    }

    function applyCourtReport() {
      const from = document.getElementById('court-rpt-from').value
      const to   = document.getElementById('court-rpt-to').value
      renderCourtReport(from, to)
    }

    function clearCourtReport() {
      document.getElementById('court-rpt-from').value = ''
      document.getElementById('court-rpt-to').value   = ''
      renderCourtReport()
    }

    // ── Coach Report ──
    const _coachBookingRawData = {{{ JSON.stringify(coachBookingRawData) }}}
    let _coachChart = null

    function renderCoachReport(from, to) {
      let rows = _coachBookingRawData
      if (from) rows = rows.filter(r => r.date >= from)
      if (to)   rows = rows.filter(r => r.date <= to)

      const map = {}
      rows.forEach(r => {
        if (!map[r.coachName]) map[r.coachName] = { coachName: r.coachName, sessions: 0, hours: 0, revenue: 0 }
        map[r.coachName].sessions++
        map[r.coachName].revenue += r.revenue
        if (r.start && r.end) {
          const [sh, sm] = r.start.split(':').map(Number)
          const [eh, em] = r.end.split(':').map(Number)
          map[r.coachName].hours += (eh * 60 + em - (sh * 60 + sm)) / 60
        }
      })

      const entries = Object.values(map).sort((a, b) => b.revenue - a.revenue)
      const totalSessions = entries.reduce((s, c) => s + c.sessions, 0)
      const totalRevenue  = entries.reduce((s, c) => s + c.revenue, 0)

      const tbody   = document.getElementById('coach-rpt-tbody')
      const titleEl = document.getElementById('coach-rpt-title')
      document.getElementById('coach-rpt-total-sessions').textContent = totalSessions || '—'
      document.getElementById('coach-rpt-total-revenue').textContent  = totalRevenue ? '฿' + totalRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 }) : '—'

      tbody.innerHTML = entries.length === 0
        ? '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:20px;">No data</td></tr>'
        : entries.map(c => `<tr>
            <td style="font-weight:600;">${c.coachName}</td>
            <td style="text-align:right;" class="td-muted">${c.sessions}</td>
            <td style="text-align:right;" class="td-muted">${c.hours.toFixed(1)} hrs</td>
            <td style="text-align:right;font-weight:600;">฿${c.revenue.toLocaleString('th-TH', { maximumFractionDigits: 0 })}</td>
            <td style="text-align:right;" class="td-muted">฿${c.sessions > 0 ? (c.revenue / c.sessions).toLocaleString('th-TH', { maximumFractionDigits: 0 }) : 0}</td>
          </tr>`).join('')

      titleEl.textContent = from || to
        ? `Coach Revenue (${from || '—'} → ${to || '—'})`
        : 'Coach Revenue (All Time)'

      const _pal = ['#2563eb','#16a34a','#d97706','#dc2626','#7c3aed','#0891b2','#db2777','#65a30d']
      function coachColor(name) {
        let h = 0
        for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) & 0xffff
        return _pal[h % _pal.length]
      }
      const labels = entries.map(c => c.coachName)
      const values = entries.map(c => c.revenue)

      if (_coachChart) {
        _coachChart.data.labels = labels
        _coachChart.data.datasets[0].data = values
        _coachChart.data.datasets[0].backgroundColor = labels.map(n => coachColor(n) + 'b3')
        _coachChart.data.datasets[0].borderColor     = labels.map(n => coachColor(n))
        _coachChart.update()
      } else {
        _coachChart = new Chart(document.getElementById('coach-rpt-chart'), {
          type: 'bar',
          data: {
            labels,
            datasets: [{
              label: 'Revenue',
              data: values,
              backgroundColor: labels.map(n => coachColor(n) + 'b3'),
              borderColor:     labels.map(n => coachColor(n)),
              borderWidth: 1, borderRadius: 4,
            }],
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, grid: { color: '#f1f5f9' },
                ticks: { callback: v => '฿' + v.toLocaleString('th-TH') } },
              x: { grid: { display: false } },
            },
          },
        })
      }
    }

    function applyCoachReport() {
      renderCoachReport(document.getElementById('coach-rpt-from').value, document.getElementById('coach-rpt-to').value)
    }
    function clearCoachReport() {
      document.getElementById('coach-rpt-from').value = ''
      document.getElementById('coach-rpt-to').value   = ''
      renderCoachReport()
    }
    function initCoachCharts() {
      window._coachChartsInited = true
      const now = new Date()
      const y = now.getFullYear(), m = String(now.getMonth() + 1).padStart(2, '0')
      const lastDay = new Date(y, now.getMonth() + 1, 0).getDate()
      const fromEl = document.getElementById('coach-rpt-from')
      const toEl   = document.getElementById('coach-rpt-to')
      if (!fromEl.value) fromEl.value = `${y}-${m}-01`
      if (!toEl.value)   toEl.value   = `${y}-${m}-${lastDay}`
      renderCoachReport(fromEl.value, toEl.value)
    }

    // restore section from URL hash on load
    const hash = window.location.hash.replace('#', '')
    if (hash === 'report-coach') {
      activateSection('report')
      switchReportSub('coach')
    } else if (hash) {
      activateSection(hash)
    }

    // ── Line chart ──
    function drawLineChart(svg) {
      const raw = svg.dataset.points || ''
      const values = raw.split(',').map(Number)
      const n = values.length
      if (n < 2) return
      const W = 420, H = 90, pad = 8
      const max = Math.max(...values, 1)
      const pts = values.map((v, i) => [
        pad + (i / (n - 1)) * (W - pad * 2),
        H - pad - (v / max) * (H - pad * 2)
      ])
      const linePts = pts.map(([x, y]) => `${x},${y}`).join(' L ')
      const areaD = `M ${pts[0][0]},${H} L ${pts.map(([x,y]) => `${x},${y}`).join(' L ')} L ${pts[n-1][0]},${H} Z`
      svg.querySelector('.line-path').setAttribute('d', `M ${linePts}`)
      svg.querySelector('.line-area').setAttribute('d', areaD)
    }
    document.querySelectorAll('.line-chart-svg').forEach(drawLineChart)

    // ── KPI refresh ──
    async function refreshStats() {
      try {
        const res = await fetch('/admin/stats')
        if (!res.ok) return
        const s = await res.json()
        const totalStatus = s.pendingCount + s.confirmedCount + s.cancelledCount
        document.getElementById('kpi-bookings').textContent      = s.todayBookings
        document.getElementById('kpi-revenue').innerHTML          = '<span class="hero-currency">฿</span>' + s.todayRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 })
        document.getElementById('kpi-customers').textContent     = s.todayCustomers
        document.getElementById('kpi-courts').textContent        = s.availableCourts
        document.getElementById('kpi-coach-revenue').textContent = '฿' + s.todayCoachRevenue.toLocaleString('th-TH', { maximumFractionDigits: 0 })
        document.getElementById('status-confirmed-count').textContent = s.confirmedCount
        document.getElementById('status-pending-count').textContent = s.pendingCount
        document.getElementById('status-cancelled-count').textContent = s.cancelledCount
        document.getElementById('status-confirmed-bar').style.width = `${totalStatus > 0 ? ((s.confirmedCount / totalStatus) * 100).toFixed(1) : 0}%`
        document.getElementById('status-pending-bar').style.width = `${totalStatus > 0 ? ((s.pendingCount / totalStatus) * 100).toFixed(1) : 0}%`
        document.getElementById('status-cancelled-bar').style.width = `${totalStatus > 0 ? ((s.cancelledCount / totalStatus) * 100).toFixed(1) : 0}%`
      } catch {}
    }

    function formatMoney(value) {
      return Number(value || 0).toLocaleString('th-TH', { maximumFractionDigits: 0 })
    }

    function formatDate(value) {
      if (!value) return '—'
      const date = new Date(value)
      if (Number.isNaN(date.getTime())) {
        const raw = String(value).slice(0, 10)
        const parts = raw.split('-')
        return parts.length === 3 ? `${parts[2]}-${parts[1]}-${parts[0]}` : String(value)
      }
      const day = String(date.getDate()).padStart(2, '0')
      const month = String(date.getMonth() + 1).padStart(2, '0')
      const year = date.getFullYear()
      return `${day}-${month}-${year}`
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;')
    }

    function renderRecentBookings(rows) {
      const tbody = document.getElementById('recent-bookings-tbody')
      if (!tbody) return
      tbody.innerHTML = rows.map((b) => `
        <tr>
          <td class="td-muted">#${b.bookingId}</td>
          <td>${escapeHtml(b.customer ? b.customer.customerName : '—')}</td>
          <td>${escapeHtml(b.court ? b.court.courtName : '—')}</td>
          <td class="td-muted">${escapeHtml(formatDate(b.bookingDate))}</td>
          <td class="td-muted">${escapeHtml(b.bookingStart)} – ${escapeHtml(b.bookingEnd)}</td>
          <td>฿${formatMoney(b.totalPrice)}</td>
          <td class="td-muted">${escapeHtml(b.payment ? b.payment.paymentMethod : '—')}</td>
          <td><span class="badge badge-${escapeHtml(b.bookingStatus)}">${escapeHtml(b.bookingStatus)}</span></td>
          <td class="td-muted">${escapeHtml(b.customer ? b.customer.customerType : '—')}</td>
        </tr>
      `).join('')
    }

    function renderCustomers(rows) {
      const tbody = document.getElementById('customers-tbody')
      if (!tbody) return
      tbody.innerHTML = rows.map((c) => `
        <tr id="customer-row-${c.customerId}">
          <td class="td-muted">${c.customerId}</td>
          <td>${escapeHtml(c.customerName)}</td>
          <td class="td-muted">${escapeHtml(c.customerEmail ?? '—')}</td>
          <td class="td-muted">${escapeHtml(c.customerPhone ?? '—')}</td>
          <td><span class="badge badge-confirmed">${escapeHtml(c.customerType)}</span></td>
          <td class="td-muted">${escapeHtml(c.tier ? c.tier.tierDesc : '—')}</td>
          <td>
            <button class="btn-action btn-edit btn-edit-customer"
              data-id="${c.customerId}"
              data-name="${escapeHtml(c.customerName)}"
              data-email="${escapeHtml(c.customerEmail ?? '')}"
              data-phone="${escapeHtml(c.customerPhone ?? '')}"
              data-type="${escapeHtml(c.customerType)}"
              data-tier="${escapeHtml(c.tierId ?? '')}"
              data-user="${escapeHtml(c.userId ?? '')}">
              Edit
            </button>
          </td>
        </tr>
      `).join('')
      bindCustomerEditButtons()
    }

    function renderUsers(rows) {
      const tbody = document.getElementById('users-tbody')
      if (!tbody) return
      tbody.innerHTML = rows.map((u) => `
        <tr id="user-row-${u.id}">
          <td class="td-muted">${u.id}</td>
          <td>${escapeHtml(u.fullName ?? '—')}</td>
          <td class="td-muted">${escapeHtml(u.username ?? '—')}</td>
          <td class="td-muted">${escapeHtml(u.email)}</td>
          <td><span class="badge ${u.role === 'admin' ? 'badge-cancelled' : 'badge-confirmed'}">${escapeHtml(u.role)}</span></td>
          <td class="td-muted">${escapeHtml(u.role === 'member' && u.customer && u.customer.tier ? u.customer.tier.tierDesc : '—')}</td>
          <td>
            <div class="action-btns">
              <button class="btn-action btn-edit btn-edit-user"
                data-id="${u.id}"
                data-fullname="${escapeHtml(u.fullName ?? '')}"
                data-username="${escapeHtml(u.username ?? '')}"
                data-email="${escapeHtml(u.email)}"
                data-role="${escapeHtml(u.role)}">
                Edit
              </button>
              <button class="btn-action cancel btn-delete-user"
                data-id="${u.id}"
                data-name="${escapeHtml(u.fullName ?? u.email)}">
                Delete
              </button>
            </div>
          </td>
        </tr>
      `).join('')
      bindUserEditButtons()
      bindUserDeleteButtons()
    }

    async function refreshAdminData() {
      try {
        const res = await fetch('/admin/data')
        if (!res.ok) return
        const data = await res.json()
        renderRecentBookings(data.recentBookings || [])
        renderCustomers(data.customers || [])
        renderUsers(data.users || [])
      } catch {}
    }

    async function refreshDashboardNow() {
      await Promise.all([refreshStats(), refreshAdminData()])
    }

    // Auto-poll ทุก 30 วินาที
    setInterval(refreshStats, 30000)
    setInterval(refreshAdminData, 30000)

    window.addEventListener('storage', (event) => {
      if (event.key === 'admin_refresh_signal' && event.newValue) {
        refreshDashboardNow()
      }
    })

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        refreshDashboardNow()
      }
    })

    // ── Coach Modal ──
    const coachOverlay  = document.getElementById('coach-modal-overlay')
    const coachTitle    = document.getElementById('coach-modal-title')
    const coachForm     = document.getElementById('coach-form')
    const coachIdInput  = document.getElementById('coach-id')
    const coachName     = document.getElementById('coach-name')
    const coachLevel    = document.getElementById('coach-level')
    const coachStatus   = document.getElementById('coach-status')
    const coachSubmit   = document.getElementById('coach-submit-btn')

    function openCoachModal({ id = '', name = '', level = '', status = 'available' } = {}) {
      coachIdInput.value  = id
      coachName.value     = name
      coachLevel.value    = level
      coachStatus.value   = status
      coachTitle.textContent = id ? 'Edit Coach' : 'Add Coach'
      coachSubmit.textContent = id ? 'Save Changes' : 'Add Coach'
      coachOverlay.style.display = 'flex'
    }
    function closeCoachModal() {
      coachOverlay.style.display = 'none'
      coachForm.reset()
    }

    document.getElementById('btn-add-coach').addEventListener('click', () => openCoachModal())
    document.getElementById('coach-modal-close').addEventListener('click', closeCoachModal)
    document.getElementById('coach-modal-cancel').addEventListener('click', closeCoachModal)
    coachOverlay.addEventListener('click', e => { if (e.target === coachOverlay) closeCoachModal() })

    document.querySelectorAll('.btn-edit-coach').forEach(btn => {
      btn.addEventListener('click', () => openCoachModal({
        id:     btn.dataset.id,
        name:   btn.dataset.name,
        level:  btn.dataset.level,
        status: btn.dataset.status,
      }))
    })

    // ── Coach Schedule Modal ──
    const DAY_NAMES = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']
    const scheduleOverlay = document.getElementById('schedule-modal-overlay')
    const scheduleCoachName = document.getElementById('schedule-coach-name')
    const scheduleDays = document.getElementById('schedule-days')
    let scheduleCoachId = null

    function openScheduleModal(coachId, coachName, schedules) {
      scheduleCoachId = coachId
      scheduleCoachName.textContent = coachName
      renderScheduleDays(schedules)
      scheduleOverlay.style.display = 'flex'
    }
    function closeScheduleModal() {
      scheduleOverlay.style.display = 'none'
    }

    function renderScheduleDays(schedules) {
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      scheduleDays.innerHTML = DAY_NAMES.map((name, day) => {
        const s = schedules.find(x => x.day === day)
        return `<div class="sched-row" id="sched-row-${day}" style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)">
          <label style="display:flex;align-items:center;gap:8px;min-width:60px;cursor:pointer">
            <input type="checkbox" id="sched-cb-${day}" ${s ? 'checked' : ''} onchange="toggleScheduleDay(${day}, this.checked)" style="width:16px;height:16px;cursor:pointer">
            <span style="font-weight:600;font-size:13px">${name}</span>
          </label>
          <div id="sched-times-${day}" style="display:flex;gap:8px;align-items:center;flex:1;${s ? '' : 'opacity:0.35;pointer-events:none'}">
            <input type="time" id="sched-start-${day}" value="${s ? s.start : '09:00'}" class="form-input" style="width:120px;padding:6px 10px" onchange="saveScheduleDay(${day})">
            <span style="color:var(--muted);font-size:13px">–</span>
            <input type="time" id="sched-end-${day}" value="${s ? s.end : '18:00'}" class="form-input" style="width:120px;padding:6px 10px" onchange="saveScheduleDay(${day})">
          </div>
          <span id="sched-status-${day}" style="font-size:11px;color:var(--muted);min-width:50px;text-align:right"></span>
        </div>`
      }).join('')
    }

    async function toggleScheduleDay(day, enabled) {
      const csrf = document.querySelector('meta[name="csrf-token"]').content
      const times = document.getElementById(`sched-times-${day}`)
      if (!enabled) {
        times.style.opacity = '0.35'
        times.style.pointerEvents = 'none'
        await fetch(`/admin/coaches/${scheduleCoachId}/schedule/${day}`, {
          method: 'DELETE', headers: { 'X-CSRF-TOKEN': csrf }
        })
        setSchedStatus(day, '')
      } else {
        times.style.opacity = '1'
        times.style.pointerEvents = ''
        await saveScheduleDay(day)
      }
    }

    async function saveScheduleDay(day) {
      const cb = document.getElementById(`sched-cb-${day}`)
      if (!cb.checked) return
      const csrf  = document.querySelector('meta[name="csrf-token"]').content
      const start = document.getElementById(`sched-start-${day}`).value
      const end   = document.getElementById(`sched-end-${day}`).value
      setSchedStatus(day, '...')
      const res = await fetch(`/admin/coaches/${scheduleCoachId}/schedule`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
        body: JSON.stringify({ dayOfWeek: day, startTime: start, endTime: end }),
      })
      setSchedStatus(day, res.ok ? 'Saved' : 'Error')
    }

    function setSchedStatus(day, text) {
      const el = document.getElementById(`sched-status-${day}`)
      if (el) el.textContent = text
    }

