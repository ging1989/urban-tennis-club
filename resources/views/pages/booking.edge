        {{-- Date picker --}}
        <div style="margin-bottom:14px;">
          <label style="font-size:12px;color:var(--muted);display:block;margin-bottom:4px;">Date</label>
          <input
            type="date"
            id="pick-date"
            value="{{ bookingDate }}"
