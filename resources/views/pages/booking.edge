          <div style="font-size:13px;color:var(--muted);margin-bottom:20px">No account needed — just fill in your info</div>

          <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:16px">
            <div>
              <label style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;display:block;margin-bottom:4px">Full name</label>
