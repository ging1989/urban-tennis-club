@layout('layouts/main')
@set('title', 'Book a Court')

@section('content')

<div style="max-width:860px;margin:0 auto;padding:24px 40px 60px">

  {{-- STEPPER --}}
  <div id="stepper" style="display:flex;align-items:center;justify-content:center;margin-bottom:32px;gap:0">
    <div class="step-wrap" data-step="1">
      <div class="step-circle active">1</div>
      <div class="step-label active">Time slot</div>
    </div>
    <div class="step-line" id="line-1"></div>
    <div class="step-wrap" data-step="2">
      <div class="step-circle idle">2</div>
      <div class="step-label">Coach</div>
    </div>
    <div class="step-line" id="line-2"></div>
    <div class="step-wrap" data-step="3">
      <div class="step-circle idle">3</div>
      <div class="step-label">Details</div>
    </div>
    <div class="step-line" id="line-3"></div>
    <div class="step-wrap" data-step="4">
      <div class="step-circle idle">4</div>
      <div class="step-label">Payment</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 300px;gap:20px;align-items:start">
    <div id="main-panel">

      {{-- STEP 1: TIME SLOT --}}
      <div id="step-1" class="step-panel">
        <div style="background:white;border-radius:16px;border:1px solid var(--clay-border);padding:24px">
          <div style="font-family:'Playfair Display',serif;font-size:20px;color:var(--clay);margin-bottom:4px">Select a court & time</div>
          <div style="font-size:13px;color:var(--muted);margin-bottom:20px">Choose your preferred court and time slot</div>

          {{-- Court selection --}}
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px">
            @each(court in courts)
            <div class="court-opt" onclick="selectCourt({{ court.courtId }}, '{{ court.courtName }}', {{ court.courtPricePerHr }})" id="court-opt-{{ court.courtId }}">
              <div style="height:60px;background:linear-gradient(135deg,#A83010,#C4520A);display:flex;align-items:center;justify-content:center">
                <div style="width:50px;height:38px;border:2px solid rgba(255,255,255,.5);position:relative">
                  <div style="position:absolute;left:50%;top:0;bottom:0;width:1px;background:rgba(255,255,255,.4)"></div>
                  <div style="position:absolute;top:50%;left:-2px;right:-2px;height:2px;background:rgba(255,255,255,.8)"></div>
                </div>
              </div>
              <div style="padding:8px 10px">
                <div style="font-size:13px;font-weight:500">{{ court.courtName }}</div>
                <div style="font-size:12px;color:var(--clay);font-weight:500">฿{{ court.courtPricePerHr }}/hr</div>
              </div>
            </div>
            @end
          </div>

          {{-- แทนที่ Date + Duration grid และ slots grid เดิมทั้งหมด --}}

        <div style="display:grid;grid-template-columns:1fr;gap:10px;margin-bottom:16px">
        <div>
            <label style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;display:block;margin-bottom:4px">Date</label>
            <input type="date" id="booking-date" onchange="updateSummary()"
            style="width:100%;padding:10px 12px;border:1.5px solid var(--clay-border);border-radius:8px;font-size:13px;font-family:'Outfit',sans-serif">
        </div>
        </div>

        <div style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">Select a time slot</div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:20px">
        <div class="time-slot" onclick="selectSlot(this,'08:00','09:00')">
            <div style="font-size:14px;font-weight:500">08:00</div>
            <div style="font-size:10px;color:var(--muted)">– 09:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'09:00','10:00')">
            <div style="font-size:14px;font-weight:500">09:00</div>
            <div style="font-size:10px;color:var(--muted)">– 10:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'10:00','11:00')">
            <div style="font-size:14px;font-weight:500">10:00</div>
            <div style="font-size:10px;color:var(--muted)">– 11:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'11:00','12:00')">
            <div style="font-size:14px;font-weight:500">11:00</div>
            <div style="font-size:10px;color:var(--muted)">– 12:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'12:00','13:00')">
            <div style="font-size:14px;font-weight:500">12:00</div>
            <div style="font-size:10px;color:var(--muted)">– 13:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'13:00','14:00')">
            <div style="font-size:14px;font-weight:500">13:00</div>
            <div style="font-size:10px;color:var(--muted)">– 14:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'14:00','15:00')">
            <div style="font-size:14px;font-weight:500">14:00</div>
            <div style="font-size:10px;color:var(--muted)">– 15:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'15:00','16:00')">
            <div style="font-size:14px;font-weight:500">15:00</div>
            <div style="font-size:10px;color:var(--muted)">– 16:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'16:00','17:00')">
            <div style="font-size:14px;font-weight:500">16:00</div>
            <div style="font-size:10px;color:var(--muted)">– 17:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'17:00','18:00')">
            <div style="font-size:14px;font-weight:500">17:00</div>
            <div style="font-size:10px;color:var(--muted)">– 18:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'18:00','19:00')">
            <div style="font-size:14px;font-weight:500">18:00</div>
            <div style="font-size:10px;color:var(--muted)">– 19:00</div>
        </div>
        <div class="time-slot" onclick="selectSlot(this,'19:00','20:00')">
            <div style="font-size:14px;font-weight:500">19:00</div>
            <div style="font-size:10px;color:var(--muted)">– 20:00</div>
        </div>
        </div>

          <button onclick="goStep(2)" style="width:100%;padding:13px;background:var(--clay);color:white;border:none;border-radius:10px;font-size:14px;font-family:'Outfit',sans-serif;cursor:pointer;font-weight:500">
            Continue →
          </button>
        </div>
      </div>

      {{-- STEP 2: COACH --}}
      <div id="step-2" class="step-panel" style="display:none">
        <div style="background:white;border-radius:16px;border:1px solid var(--clay-border);padding:24px">
          <div style="font-family:'Playfair Display',serif;font-size:20px;color:var(--clay);margin-bottom:4px">Add a coach</div>
          <div style="font-size:13px;color:var(--muted);margin-bottom:20px">Optional — skip if you don't need one</div>

          <div onclick="selectCoach(0, 'No coach', 0)" id="coach-opt-0"
            style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1.5px dashed var(--clay-border);border-radius:11px;cursor:pointer;margin-bottom:10px;font-size:13px;color:var(--muted)">
            <div style="width:36px;height:36px;border-radius:50%;background:var(--faint);display:flex;align-items:center;justify-content:center;font-size:16px">—</div>
            <div><div style="font-weight:500;color:var(--ink)">No coach</div><div style="font-size:11px">Court only</div></div>
          </div>

          @each(coach in coaches)
          <div onclick="selectCoach({{ coach.coachId }}, '{{ coach.coachName }}', {{ coach.coachPricing.coachPrice }})" id="coach-opt-{{ coach.coachId }}"
            style="display:flex;align-items:center;gap:10px;padding:12px;border:1.5px solid var(--clay-border);border-radius:11px;cursor:pointer;margin-bottom:8px;background:white;
            {{ coach.coachStatus !== 'available' ? 'opacity:.45;pointer-events:none' : '' }}">
            <div style="width:40px;height:40px;border-radius:50%;background:var(--clay-pale);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:15px;color:var(--clay);flex-shrink:0">
              {{ coach.coachName.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase() }}
            </div>
            <div style="flex:1">
              <div style="font-size:13px;font-weight:500">{{ coach.coachName }}</div>
              <div style="font-size:11px;color:var(--muted)">{{ coach.coachPricing.coachLevelDesc }}</div>
            </div>
            <div style="text-align:right">
              <div style="font-size:13px;font-weight:500;color:var(--clay)">฿{{ coach.coachPricing.coachPrice }}/hr</div>
              <div style="font-size:10px;color:{{ coach.coachStatus === 'available' ? '#6BAC2C' : '#D4900A' }}">
                {{ coach.coachStatus === 'available' ? 'Available' : 'Unavailable' }}
              </div>
            </div>
          </div>
          @end

          <div style="display:flex;gap:8px;margin-top:16px">
            <button onclick="goStep(1)" style="flex:1;padding:11px;background:transparent;color:var(--clay);border:1.5px solid var(--clay-border);border-radius:10px;font-size:13px;font-family:'Outfit',sans-serif;cursor:pointer">← Back</button>
            <button onclick="goStep(3)" style="flex:2;padding:13px;background:var(--clay);color:white;border:none;border-radius:10px;font-size:14px;font-family:'Outfit',sans-serif;cursor:pointer;font-weight:500">Continue →</button>
          </div>
        </div>
      </div>

      {{-- STEP 3: DETAILS --}}
      <div id="step-3" class="step-panel" style="display:none">
        <div style="background:white;border-radius:16px;border:1px solid var(--clay-border);padding:24px">
