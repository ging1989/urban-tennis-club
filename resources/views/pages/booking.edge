              <div>
                <label style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;display:block;margin-bottom:4px">Phone</label>
                <input type="text" id="guest-phone" placeholder="0812345678"
                  style="width:100%;padding:10px 12px;border:1.5px solid var(--clay-border);border-radius:8px;font-size:13px;font-family:'Outfit',sans-serif">
              </div>
              <div>
                <label style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;display:block;margin-bottom:4px">Email</label>
                <input type="email" id="guest-email" placeholder="email@example.com"
                  style="width:100%;padding:10px 12px;border:1.5px solid var(--clay-border);border-radius:8px;font-size:13px;font-family:'Outfit',sans-serif">
              </div>
            </div>
          </div>

          <div style="display:flex;align-items:center;gap:10px;margin:16px 0;font-size:12px;color:var(--muted)">
            <div style="flex:1;height:1px;background:var(--clay-border)"></div>
            or
            <div style="flex:1;height:1px;background:var(--clay-border)"></div>
          </div>

          <a href="/login" style="display:block;width:100%;padding:11px;border:1.5px solid var(--clay-border);border-radius:9px;font-size:13px;font-family:'Outfit',sans-serif;cursor:pointer;color:var(--clay);font-weight:500;text-align:center;text-decoration:none">
            Login as member to get discount →
          </a>

          <div style="display:flex;gap:8px;margin-top:16px">
            <button onclick="goStep(2)" style="flex:1;padding:11px;background:transparent;color:var(--clay);border:1.5px solid var(--clay-border);border-radius:10px;font-size:13px;font-family:'Outfit',sans-serif;cursor:pointer">← Back</button>
            <button onclick="goStep(4)" style="flex:2;padding:13px;background:var(--clay);color:white;border:none;border-radius:10px;font-size:14px;font-family:'Outfit',sans-serif;cursor:pointer;font-weight:500">Continue to payment →</button>
          </div>
        </div>
      </div>

      {{-- STEP 4: PAYMENT --}}
      <div id="step-4" class="step-panel" style="display:none">
        <div style="background:white;border-radius:16px;border:1px solid var(--clay-border);padding:24px">
          <div style="font-family:'Playfair Display',serif;font-size:20px;color:var(--clay);margin-bottom:4px">Payment</div>
          <div style="font-size:13px;color:var(--muted);margin-bottom:20px">Choose your payment method</div>

          <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px">
            <div class="pay-opt" onclick="selectPayment(this,'cash')">
              <div style="font-size:18px">💵</div>
              <div><div style="font-size:13px;font-weight:500">Cash</div><div style="font-size:11px;color:var(--muted)">Pay at the counter</div></div>
              <div class="pay-radio" id="radio-cash"></div>
            </div>
            <div class="pay-opt" onclick="selectPayment(this,'qr')">
              <div style="font-size:18px">📱</div>
              <div><div style="font-size:13px;font-weight:500">QR Code</div><div style="font-size:11px;color:var(--muted)">PromptPay / Thai QR</div></div>
              <div class="pay-radio" id="radio-qr"></div>
            </div>
            <div class="pay-opt" onclick="selectPayment(this,'transfer')">
              <div style="font-size:18px">🏦</div>
              <div><div style="font-size:13px;font-weight:500">Bank Transfer</div><div style="font-size:11px;color:var(--muted)">Transfer & upload slip</div></div>
              <div class="pay-radio" id="radio-transfer"></div>
            </div>
            <div class="pay-opt" onclick="selectPayment(this,'card')">
              <div style="font-size:18px">💳</div>
              <div><div style="font-size:13px;font-weight:500">Credit / Debit Card</div><div style="font-size:11px;color:var(--muted)">Visa, Mastercard</div></div>
              <div class="pay-radio" id="radio-card"></div>
            </div>
          </div>

          <div style="background:var(--faint);border-radius:10px;padding:14px 16px;margin-bottom:16px" id="order-summary">
            <div style="font-size:11px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">Order summary</div>
            <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px">
              <span style="color:var(--muted)" id="sum-court-label">Court</span>
              <span id="sum-court-price">—</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px" id="sum-coach-row" style="display:none">
              <span style="color:var(--muted)" id="sum-coach-label">Coach</span>
              <span id="sum-coach-price">—</span>
            </div>
            <div style="height:1px;background:var(--clay-border);margin:8px 0"></div>
            <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:500">
              <span>Total</span>
              <span style="color:var(--clay);font-family:'Playfair Display',serif;font-size:18px" id="sum-total">—</span>
            </div>
          </div>

          <div style="display:flex;gap:8px">
            <button onclick="goStep(3)" style="flex:1;padding:11px;background:transparent;color:var(--clay);border:1.5px solid var(--clay-border);border-radius:10px;font-size:13px;font-family:'Outfit',sans-serif;cursor:pointer">← Back</button>
            <button onclick="submitBooking()" style="flex:2;padding:13px;background:var(--clay);color:white;border:none;border-radius:10px;font-size:14px;font-family:'Outfit',sans-serif;cursor:pointer;font-weight:500">
              Confirm booking →
            </button>
          </div>
        </div>
      </div>

      {{-- STEP 5: SUCCESS --}}
      <div id="step-5" class="step-panel" style="display:none">
        <div style="background:white;border-radius:16px;border:1px solid var(--clay-border);padding:32px;text-align:center">
          <div style="width:64px;height:64px;border-radius:50%;background:var(--clay);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:28px;color:white">✓</div>
          <h2 style="font-size:28px;color:var(--clay);margin-bottom:6px">Booking confirmed!</h2>
          <div id="booking-ref" style="display:inline-block;font-size:13px;background:var(--clay-pale);color:var(--clay-warm);padding:4px 14px;border-radius:20px;margin-bottom:20px;font-weight:500"></div>
          <div id="success-details" style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px;text-align:left"></div>
          <a href="/" style="display:inline-block;padding:12px 28px;background:var(--clay);color:white;border-radius:9px;text-decoration:none;font-size:14px;font-weight:500">
            Back to home →
          </a>
        </div>
      </div>

    </div>

    {{-- SIDEBAR --}}
    <div id="sidebar" style="background:white;border-radius:16px;border:1px solid var(--clay-border);padding:20px;position:sticky;top:80px">
      <div style="font-family:'Playfair Display',serif;font-size:17px;color:var(--clay);margin-bottom:16px">Booking summary</div>
      <div id="sidebar-content">
        <div style="font-size:13px;color:var(--muted)">Select a court to begin</div>
      </div>
    </div>
  </div>
</div>

<style>
.step-wrap { display:flex;flex-direction:column;align-items:center;gap:0 }
.step-circle { width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-family:'Playfair Display',serif;flex-shrink:0;transition:all .2s }
.step-circle.active { background:var(--clay);color:white;box-shadow:0 0 0 4px var(--clay-pale) }
.step-circle.done { background:var(--clay);color:white }
.step-circle.idle { background:white;color:var(--muted);border:1.5px solid var(--clay-border) }
.step-label { font-size:11px;color:var(--muted);margin-top:4px;white-space:nowrap }
.step-label.active { color:var(--clay);font-weight:500 }
.step-line { width:60px;height:1.5px;background:var(--clay-border);margin:0 4px;margin-bottom:18px;flex-shrink:0;transition:background .2s }
.step-line.done { background:var(--clay) }
.court-opt { border:1.5px solid var(--clay-border);border-radius:12px;overflow:hidden;cursor:pointer;transition:all .15s }
.court-opt:hover { border-color:var(--clay-warm) }
.court-opt.selected { border:2px solid var(--clay);background:var(--clay-pale) }
.time-slot { padding:9px 4px;text-align:center;font-size:12px;border:1.5px solid var(--clay-border);border-radius:8px;cursor:pointer;background:white;transition:all .12s }
.time-slot:hover { border-color:var(--clay-warm);background:var(--clay-pale);color:var(--clay) }
.time-slot.selected { background:var(--clay);color:white;border-color:var(--clay) }
.pay-opt { display:flex;align-items:center;gap:12px;padding:12px 14px;border:1.5px solid var(--clay-border);border-radius:11px;cursor:pointer;background:white;transition:all .15s }
.pay-opt:hover { border-color:var(--clay-warm) }
.pay-opt.selected { border:2px solid var(--clay);background:var(--clay-pale) }
.pay-radio { width:16px;height:16px;border-radius:50%;border:1.5px solid var(--clay-border);margin-left:auto;flex-shrink:0 }
.pay-radio.on::after { content:'';display:block;width:8px;height:8px;border-radius:50%;background:var(--clay);margin:3px }
</style>

<script>
let booking = { courtId: null, courtName: '', courtPrice: 0, date: '', start: '', end: '', dur: 1, coachId: 0, coachName: '', coachPrice: 0, payment: '' }
let currentStep = 1

function goStep(n) {
  document.getElementById('step-' + currentStep).style.display = 'none'
  currentStep = n
  document.getElementById('step-' + n).style.display = 'block'
  updateStepper()
  updateSummary()
  if (n === 4) renderOrderSummary()
}

function updateStepper() {
  for (let i = 1; i <= 4; i++) {
    const wrap = document.querySelector('.step-wrap[data-step="' + i + '"]')
    const circle = wrap.querySelector('.step-circle')
    const label = wrap.querySelector('.step-label')
    circle.className = 'step-circle ' + (i < currentStep ? 'done' : i === currentStep ? 'active' : 'idle')
    circle.textContent = i < currentStep ? '✓' : i
    label.className = 'step-label' + (i === currentStep ? ' active' : '')
    if (i < 4) {
      document.getElementById('line-' + i).className = 'step-line' + (i < currentStep ? ' done' : '')
    }
  }
}

function selectCourt(id, name, price) {
  document.querySelectorAll('.court-opt').forEach(el => el.classList.remove('selected'))
  document.getElementById('court-opt-' + id).classList.add('selected')
  booking.courtId = id
  booking.courtName = name
  booking.courtPrice = price
  updateSummary()
}

function selectSlot(el, start, end) {
  document.querySelectorAll('.time-slot').forEach(s => s.classList.remove('selected'))
  el.classList.add('selected')
  booking.start = start
  booking.end = end
  updateSummary()
}

function selectCoach(id, name, price) {
  document.querySelectorAll('[id^="coach-opt-"]').forEach(el => {
    el.style.border = '1.5px solid var(--clay-border)'
    el.style.background = 'white'
  })
  const el = document.getElementById('coach-opt-' + id)
  el.style.border = '2px solid var(--clay)'
  el.style.background = 'var(--clay-pale)'
  booking.coachId = id
  booking.coachName = name
  booking.coachPrice = price
  updateSummary()
}

function selectPayment(el, method) {
  document.querySelectorAll('.pay-opt').forEach(p => {
    p.classList.remove('selected')
    p.querySelector('.pay-radio').className = 'pay-radio'
  })
  el.classList.add('selected')
  el.querySelector('.pay-radio').className = 'pay-radio on'
  booking.payment = method
}

function updateSummary() {
  booking.dur = parseInt(document.getElementById('booking-dur')?.value || 1)
  booking.date = document.getElementById('booking-date')?.value || ''
  const courtTotal = booking.courtPrice * booking.dur
  const coachTotal = booking.coachPrice * booking.dur
  const total = courtTotal + coachTotal

  let html = ''
  if (booking.courtName) html += `<div style="display:flex;justify-content:space-between;font-size:13px;padding:7px 0;border-bottom:1px solid var(--clay-border)"><span style="color:var(--muted)">Court</span><span style="font-weight:500">${booking.courtName}</span></div>`
  if (booking.date) html += `<div style="display:flex;justify-content:space-between;font-size:13px;padding:7px 0;border-bottom:1px solid var(--clay-border)"><span style="color:var(--muted)">Date</span><span style="font-weight:500">${booking.date}</span></div>`
  if (booking.start) html += `<div style="display:flex;justify-content:space-between;font-size:13px;padding:7px 0;border-bottom:1px solid var(--clay-border)"><span style="color:var(--muted)">Time</span><span style="font-weight:500">${booking.start} · ${booking.dur}h</span></div>`
  if (booking.coachName && booking.coachId > 0) html += `<div style="display:flex;justify-content:space-between;font-size:13px;padding:7px 0;border-bottom:1px solid var(--clay-border)"><span style="color:var(--muted)">Coach</span><span style="font-weight:500">${booking.coachName}</span></div>`
  if (total > 0) html += `<div style="background:var(--clay);border-radius:10px;padding:12px 14px;display:flex;justify-content:space-between;align-items:center;color:white;margin-top:12px"><span style="font-size:12px;opacity:.8">Total</span><strong style="font-family:'Playfair Display',serif;font-size:22px">฿${total.toLocaleString()}</strong></div>`

  document.getElementById('sidebar-content').innerHTML = html || '<div style="font-size:13px;color:var(--muted)">Select a court to begin</div>'
}

function renderOrderSummary() {
  booking.dur = parseInt(document.getElementById('booking-dur')?.value || 1)
  const courtTotal = booking.courtPrice * booking.dur
  const coachTotal = booking.coachPrice * booking.dur
  const total = courtTotal + coachTotal
  document.getElementById('sum-court-label').textContent = booking.courtName + ' × ' + booking.dur + 'h'
  document.getElementById('sum-court-price').textContent = '฿' + courtTotal.toLocaleString()
  if (booking.coachId > 0) {
    document.getElementById('sum-coach-row').style.display = 'flex'
    document.getElementById('sum-coach-label').textContent = booking.coachName + ' × ' + booking.dur + 'h'
    document.getElementById('sum-coach-price').textContent = '฿' + coachTotal.toLocaleString()
  }
  document.getElementById('sum-total').textContent = '฿' + total.toLocaleString()
}

function submitBooking() {
  if (!booking.courtId || !booking.start || !booking.payment) {
    alert('Please complete all required fields')
    return
  }
  const name = document.getElementById('guest-name').value
  const phone = document.getElementById('guest-phone').value
  if (!name || !phone) {
    alert('Please fill in your name and phone number')
    return
  }

  const dur = parseInt(document.getElementById('booking-dur').value)
  const [sh, sm] = booking.start.split(':').map(Number)
  const endH = sh + dur
  const endTime = String(endH).padStart(2, '0') + ':' + String(sm).padStart(2, '0')

  const form = document.createElement('form')
  form.method = 'POST'
  form.action = '/bookings'

  const fields = {
    courtId: booking.courtId,
    bookingDate: booking.date,
    bookingStart: booking.start,
    bookingEnd: endTime,
    scheduleId: booking.coachId > 0 ? booking.coachId : '',
    customerName: name,
    customerPhone: phone,
    customerEmail: document.getElementById('guest-email').value,
    paymentMethod: booking.payment,
  }

  for (const [key, val] of Object.entries(fields)) {
    const input = document.createElement('input')
    input.type = 'hidden'
    input.name = key
    input.value = val
    form.appendChild(input)
  }

  const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content')
  if (csrf) {
    const csrfInput = document.createElement('input')
    csrfInput.type = 'hidden'
    csrfInput.name = '_csrf'
    csrfInput.value = csrf
    form.appendChild(csrfInput)
  }

  document.body.appendChild(form)
  form.submit()
}
</script>

@endsection

@end