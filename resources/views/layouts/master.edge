</head>
<body>

  <nav class="nav-bar">
    <div class="nav-container">
      <div class="logo">
        <span>Urban Tennis Club</span>
      </div>
      <ul class="nav-menu">
        <li><a href="/">Home</a></li>
        <li><a href="/courts">Courts</a></li>
        <li><a href="/coaches">Coach</a></li>
        <li><a href="#">Contact</a></li>
        @if(auth.user && auth.user.role !== 'admin')
          <li><a href="/member/profile" style="color:#8B2500;font-weight:600;">My Profile</a></li>
        @end
      </ul>
      <div class="auth-menu">
        @if(auth.user)
          <a
            href="{{ auth.user.role === 'admin' ? route('admin.profile') : route('member.profile') }}"
            style="display:inline-flex;align-items:center;gap:6px;font-size:14px;font-weight:600;color:#202124;background:#f0f0f0;border:1px solid #ddd;border-radius:20px;padding:6px 16px;text-decoration:none;"
          >
            👤 {{ auth.user.fullName ?? auth.user.email }}
          </a>
          <form action="{{ route('session.destroy') }}" method="post" style="display: inline;">
            {{ csrfField() }}
            <button type="submit" style="
              background: transparent;
              border: 1px solid rgba(0,0,0,0.15);
              padding: 7px 16px;
              border-radius: 6px;
              font-size: 13px;
              font-weight: 600;
              cursor: pointer;
              font-family: 'Google Sans', sans-serif;
            ">Logout</button>
          </form>
        @else
          <a href="{{ route('session.create') }}">Login</a>
          <a class="register-button" href="{{ route('new_account.create') }}">Register</a>
        @end
      </div>
    </div>
  </nav>

  <main>
    @!section('content')
  </main>

  <script src="https://cdn.jsdelivr.net/npm/jquery@3/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/semantic-ui@2/dist/semantic.min.js"></script>
</body>
</html>
