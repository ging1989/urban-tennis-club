<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Court Booking</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/semantic-ui@2/dist/semantic.min.css">
  <link rel="stylesheet" href="/css/app.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <meta name="csrf-token" content="{{ csrfToken }}">
</head>
<body>

  <nav class="nav-bar">
    <div class="nav-container">
      <div class="logo">
        <span>Court Booking</span>
      </div>
      <ul class="nav-menu">
        <li><a href="/">Home</a></li>
        <li><a href="/courts">Courts</a></li>
        <li><a href="/coaches">Coach</a></li>
        <li><a href="#">Contact</a></li>
      </ul>
      <div class="auth-menu">
        @if(auth.user)
          <span style="font-size: 14px; color:#6b7a99">
            Hello, {{ auth.user.fullName ?? auth.user.email }}
          </span>
          <form action="{{ route('session.destroy') }}" method="post" style="display: inline;">
            {{ csrfField() }}
            <button type="submit" style="
              background: transparent;
              border: 1px solid rgba(0,0,0,0.15);
              padding: 7px 16px;
              border-radius: 6px;
              font-size: 13px;
              font-weight: 600;
              cursor: pointer;
              font-family: 'DM Sans', sans-serif;
            ">Logout</button>
          </form>
        @else
          <a href="{{ route('session.create') }}">Login</a>
          <a class="register-button" href="{{ route('new_account.create') }}">Register</a>
        @end
      </div>
    </div>
  </nav>

  <main>
    {{{ await $slots.main() }}}
  </main>

  <script src="https://cdn.jsdelivr.net/npm/jquery@3/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/semantic-ui@2/dist/semantic.min.js"></script>
</body>
</html>
